---
import Layout from '../layouts/Layout.astro';
import "../styles/global.css";
import { sanityClient } from '../lib/sanity'
import Footer from '../components/Footer.astro';
import { DEFAULT_LANG, translations } from '../i18n/translations';
import { urlFor } from "../lib/sanityImageUrl";

type LocalizedText = {
  es?: string
  en?: string
}

type ProjectTag = {
  slug?: {
    current?: string
  }
  label?: LocalizedText
}

type SanityTag = {
  _id: string
  featured?: boolean
  slug?: {
    current?: string
  }
  label?: LocalizedText
}

type ProjectLink = {
  label?: LocalizedText
  url?: string
}

type SanityProject = {
  titulo?: LocalizedText
  descripcioncorta?: LocalizedText
  imagencover?: {
    alt?: string
    crop?: {
      _type?: string
      top?: number
      bottom?: number
      left?: number
      right?: number
    }
    hotspot?: {
      _type?: string
      x?: number
      y?: number
      height?: number
      width?: number
    }
    asset?: {
      _ref?: string
      _type?: "reference"
    }
  }
  tags?: (ProjectTag | null)[]
  links?: (ProjectLink | null)[]
  slug?: {
    current?: string
  }
}

type ProjectCard = {
  titulo: string
  tituloEs: string
  tituloEn: string
  descripcion: string
  descripcionEs: string
  descripcionEn: string
  imagencoverUrl?: string
  imagencoverAlt?: string
  tagIds: string[]
  tags: string[]
  tagsEs: string[]
  tagsEn: string[]
  links: { label: string; labelEs: string; labelEn: string; url: string }[]
  slug?: {
    current?: string
  }
}

type TagFilterOption = {
  id: string
  label: string
  labelEs: string
  labelEn: string
}

const defaultLang = DEFAULT_LANG as 'es' | 'en';

const pickLocalized = (value: LocalizedText | undefined, lang: 'es' | 'en') => {
  if (!value) return '';
  return lang === 'en' ? value.en ?? value.es ?? '' : value.es ?? value.en ?? '';
}

const getLocalizedTags = (tags: (ProjectTag | null)[] | undefined, lang: 'es' | 'en') =>
  (tags ?? [])
    .map((tag) => {
      if (!tag?.label) return '';
      return lang === 'en'
        ? tag.label.en ?? tag.label.es ?? ''
        : tag.label.es ?? tag.label.en ?? '';
    })
    .filter(Boolean)

const getProjectTagIds = (tags: (ProjectTag | null)[] | undefined) =>
  (tags ?? [])
    .map((tag) => tag?.slug?.current ?? '')
    .filter(Boolean)

const getLocalizedLinks = (links: (ProjectLink | null)[] | undefined) =>
  (links ?? [])
    .filter((link): link is ProjectLink => Boolean(link?.url))
    .map((link) => {
      const labelEs = link.label?.es ?? link.label?.en ?? 'Ver enlace';
      const labelEn = link.label?.en ?? link.label?.es ?? 'View link';

      return {
        label: pickLocalized(link.label, defaultLang) || labelEs,
        labelEs,
        labelEn,
        url: link.url as string,
      };
    })

const projectsRaw = await sanityClient.fetch<SanityProject[]>(`
*[_type == "proyecto"][]{
  titulo{es,en},
  descripcioncorta{es,en},
  imagencover{
    alt,
    crop,
    hotspot,
    asset
  },
  tags[]->{
    slug,
    label{es,en}
  },
  links[]{
    label{es,en},
    url
  },
  slug,
}
`);

const tagsRaw = await sanityClient.fetch<SanityTag[]>(`
*[_type == "tag" && coalesce(featured, false) == true] | order(coalesce(label.es, label.en) asc) {
  _id,
  featured,
  slug,
  label{es,en}
}
`);

const tagsForFilter: TagFilterOption[] = tagsRaw
  .map((tag) => {
    const id = tag.slug?.current ?? tag._id;
    const labelEs = pickLocalized(tag.label, 'es') || 'Etiqueta';
    const labelEn = pickLocalized(tag.label, 'en') || 'Tag';

    return {
      id,
      label: pickLocalized(tag.label, defaultLang) || labelEs,
      labelEs,
      labelEn,
    };
  })
  .filter((tag) => Boolean(tag.id));

const projects: ProjectCard[] = projectsRaw.map((project) => {
  const tituloEs = pickLocalized(project.titulo, 'es');
  const tituloEn = pickLocalized(project.titulo, 'en');
  const descripcionEs = pickLocalized(project.descripcioncorta, 'es');
  const descripcionEn = pickLocalized(project.descripcioncorta, 'en');

  let imagencoverUrl = "";
  let imagencoverAlt = project.imagencover?.alt ?? tituloEs ?? "Imagen de proyecto";
  if (project.imagencover?.asset?._ref) {
    imagencoverUrl = urlFor(project.imagencover)
      .width(800)
      .format("webp")
      .quality(80)
      .url();
  }

  return {
    titulo: pickLocalized(project.titulo, defaultLang),
    tituloEs,
    tituloEn,
    descripcion: pickLocalized(project.descripcioncorta, defaultLang),
    descripcionEs,
    descripcionEn,
    imagencoverUrl,
    imagencoverAlt,
    tagIds: getProjectTagIds(project.tags),
    tags: getLocalizedTags(project.tags, defaultLang),
    tagsEs: getLocalizedTags(project.tags, 'es'),
    tagsEn: getLocalizedTags(project.tags, 'en'),
    links: getLocalizedLinks(project.links),
    slug: project.slug,
  };
});

const pageDictionary = translations;


---

<Layout>
      <section

    aria-label="Sección principal"
      id="proyectos"
        style="margin: 0 auto; width: 100%; max-width: 1800px; "
  class="px-6 sm:px-12 lg:px-24 pb-12"
  >

  <div class="mb-12 sm:mb-16" data-tag-filter-root>
    <div class="flex flex-wrap gap-2">
      {tagsForFilter.map((tag) => (
        <button
          type="button"
          class="chip transition-colors duration-200 cursor-pointer hover:bg-white/50 hover:text-black"
          data-tag-filter-button
          data-tag-id={tag.id}
          data-es={tag.labelEs}
          data-en={tag.labelEn}
          aria-pressed="false"
        >
          {tag.label}
        </button>
      ))}
    </div>

    <div class="mt-4 hidden items-center gap-2 text-sm text-neutral-300" data-tag-filter-active-wrap>
      <span data-tag-filter-viewing-text>Viendo</span>
      <button
        type="button"
        class="cursor-pointer inline-flex items-center gap-2 rounded-full border border-neutral-600 bg-neutral-900 px-3 py-1 text-white"
        data-tag-filter-reset
      >
        <span data-tag-filter-active-label></span>
        <span aria-hidden="true" class="text-white/90">x</span>
      </button>
    </div>

    <div class="mt-4 p-2 text-xl text-neutral-300 text-center w-full bg-neutral-900 aspect-[16/9] flex items-center justify-center rounded-2xl" data-tag-empty-state>
      Trabajando en más proyectos...proximamente
    </div>
   
     </div>

 
  {projects.map((project, idx) => (
    <article
      class:list={[
        "project-entry",
        idx < projects.length - 1 ? "mb-24 sm:mb-32" : ""
      ]}
      aria-label={project.titulo}
      data-project-tag-ids={JSON.stringify(project.tagIds)}
    >
 
      <!-- ── TOP ROW: título + cover ── -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-start mb-6">
 
        <!-- Left: título + meta -->
        <div class="flex flex-col gap-5 transition-all duration-300 ease-in-out">
 
          <!-- Título + chevron -->
          <div class="flex items-center gap-4">
            <h2
  class="font-manrope font-black  leading-none text-neutral-100
         text-[clamp(2.8rem,3.5vw,5rem)] uppercase"
  style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"
  data-i18n-myprojects-title
  data-es={project.tituloEs}
  data-en={project.tituloEn}
>
              {project.titulo}
            </h2>
            <!-- Chevron down -->
            {/* <svg
              xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
              class="project-chevron w-8 h-8 sm:w-10 sm:h-10 text-neutral-400 shrink-0 mt-1"
              aria-hidden="true"
            >
              <path d="m6 9 6 6 6-6"/>
            </svg> */}
          </div>
 
          <!-- Category chips -->
          <div
            class="flex flex-wrap gap-2"
            data-i18n-myprojects-tags
            data-es={JSON.stringify(project.tagsEs)}
            data-en={JSON.stringify(project.tagsEn)}
          >
            {project.tags?.map((tag) => (
              <span class="chip">{tag}</span>
            ))}
          </div>
 
          <!-- Descripción corta -->
          <div class="mt-1">
            {/* <p class="font-inter text-xs text-neutral-500 uppercase tracking-widest mb-3">
              Introducción tiene asociado:
            </p> */}
            <p
              class="text-lg text-neutral-400 leading-relaxed"
              data-i18n-myprojects-description
              data-es={project.descripcionEs}
              data-en={project.descripcionEn}
            >
              {project.descripcion}
            </p>
          </div>

          {/* {project.links && project.links.length > 0 && (
            <div class="mt-2 flex flex-wrap gap-2">
              {project.links.map((link) => (
                <a
                  href={link.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="chip"
                >
                  <span
                    data-i18n-myprojects-link-label
                    data-es={link.labelEs}
                    data-en={link.labelEn}
                  >
                    {link.label}
                  </span>
                </a>
              ))}
            </div>
          )} */}

            <!-- Reemplaza tu <a> existente por este bloque completo -->
 
<div class="cta-wrap">
 
  <!-- Blobs que se alejan en hover -->
  <span class="cta-blob cta-blob--tl" aria-hidden="true"></span>
  <span class="cta-blob cta-blob--tr" aria-hidden="true"></span>
  <span class="cta-blob cta-blob--bl" aria-hidden="true"></span>
  <span class="cta-blob cta-blob--br" aria-hidden="true"></span>
 
  <a
    href={`/proyecto/${project.slug?.current}`}
    class="cta-link inline-flex w-fit items-center gap-2 px-8 py-3 rounded-full
           bg-neutral-100 text-black font-manrope font-semibold text-sm
           transition-all duration-300 hover:bg-white hover:-translate-y-px"
  >
    <span data-i18n-myprojects="seeProject">
      {pageDictionary[defaultLang].general.seeProject}
    </span>
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4">
      <path fill-rule="evenodd" d="M3 10a.75.75 0 0 1 .75-.75h10.638L10.23 5.29a.75.75 0 1 1 1.04-1.08l5.5 5.25a.75.75 0 0 1 0 1.08l-5.5 5.25a.75.75 0 1 1-1.04-1.08l4.158-3.96H3.75A.75.75 0 0 1 3 10Z" clip-rule="evenodd" />
    </svg>
  </a>
 
</div>
 
        
        </div>
 
        <!-- Right: cover image -->
          <a
    href={`/proyecto/${project.slug?.current}`}
        class="project-img-wrap rounded-2xl overflow-hidden bg-[#191a1a]
                    ">
          {project.imagencoverUrl ? (
            <img
              src={project.imagencoverUrl}
              alt={project.imagencoverAlt}
              class="w-full h-full object-cover"
              loading="lazy"
            />
          ) : (
            <div class="project-img-placeholder flex items-center justify-center h-full">
              
            </div>
          )}
        </a>
 
      </div>
      <!-- /TOP ROW -->
 
      <!-- /GALLERY -->
 
    </article>
  ))}
 
</section>
<Footer/>
</Layout>

<script>
  import { LANG_STORAGE_KEY, translations } from '../i18n/translations';

  const MYPROJECTS_I18N = {
    es: translations.es.general,
    en: translations.en.general,
  };

  const FILTER_COPY = {
    es: {
      viewing: 'Viendo',
      empty: 'Trabajando en más proyectos...proximamente',
    },
    en: {
      viewing: 'Viewing',
      empty: 'Working on more projects...coming soon',
    },
  };

  function initMyProjectsLanguage() {
    const sectionRoot = document.querySelector<HTMLElement>('[data-tag-filter-root]')?.closest('section');
    if (!sectionRoot || sectionRoot.dataset.myprojectsInitialized === 'true') return;
    sectionRoot.dataset.myprojectsInitialized = 'true';

    const i18nNodes = Array.from(
      document.querySelectorAll<HTMLElement>('[data-i18n-myprojects]'),
    );
    const projectTitleNodes = Array.from(
      document.querySelectorAll<HTMLElement>('[data-i18n-myprojects-title]'),
    );
    const projectDescriptionNodes = Array.from(
      document.querySelectorAll<HTMLElement>('[data-i18n-myprojects-description]'),
    );
    const projectTagsNodes = Array.from(
      document.querySelectorAll<HTMLElement>('[data-i18n-myprojects-tags]'),
    );
    const projectLinkNodes = Array.from(
      document.querySelectorAll<HTMLElement>('[data-i18n-myprojects-link-label]'),
    );
    const projectEntryNodes = Array.from(
      document.querySelectorAll<HTMLElement>('.project-entry'),
    );
    const tagFilterButtons = Array.from(
      document.querySelectorAll<HTMLButtonElement>('[data-tag-filter-button]'),
    );
    const activeFilterWrap = document.querySelector<HTMLElement>('[data-tag-filter-active-wrap]');
    const activeFilterLabel = document.querySelector<HTMLElement>('[data-tag-filter-active-label]');
    const activeFilterViewingText = document.querySelector<HTMLElement>('[data-tag-filter-viewing-text]');
    const tagFilterResetButton = document.querySelector<HTMLButtonElement>('[data-tag-filter-reset]');
    const emptyStateNode = document.querySelector<HTMLElement>('[data-tag-empty-state]');

    let selectedTagId: string | null = null;
    let currentLang: 'es' | 'en' = 'es';

    function sanitizeLang(value: string | null): 'es' | 'en' {
      return value === 'en' ? 'en' : 'es';
    }

    function parseLocalizedList(node: HTMLElement, lang: 'es' | 'en') {
      const raw = node.getAttribute(`data-${lang}`) ?? '[]';

      try {
        const parsed = JSON.parse(raw);
        if (!Array.isArray(parsed)) return [];
        return parsed.filter((item): item is string => typeof item === 'string');
      } catch {
        return [];
      }
    }

    function parseTagIds(node: HTMLElement) {
      const raw = node.dataset.projectTagIds ?? '[]';

      try {
        const parsed = JSON.parse(raw);
        if (!Array.isArray(parsed)) return [];
        return parsed.filter((item): item is string => typeof item === 'string');
      } catch {
        return [];
      }
    }

    function getTagLabel(button: HTMLButtonElement, lang: 'es' | 'en') {
      return (button.getAttribute(`data-${lang}`) ?? button.textContent ?? '').trim();
    }

    function updateActiveFilter(lang: 'es' | 'en') {
      if (!activeFilterWrap || !activeFilterLabel || !activeFilterViewingText) return;

      activeFilterViewingText.textContent = FILTER_COPY[lang].viewing;

      if (!selectedTagId) {
        activeFilterWrap.classList.add('hidden');
        activeFilterWrap.classList.remove('inline-flex');
        activeFilterLabel.textContent = '';
        return;
      }

      const selectedButton = tagFilterButtons.find((button) => button.dataset.tagId === selectedTagId);
      const selectedLabel = selectedButton ? getTagLabel(selectedButton, lang) : '';

      activeFilterLabel.textContent = selectedLabel;
      activeFilterWrap.classList.remove('hidden');
      activeFilterWrap.classList.add('inline-flex');
    }

    function applyProjectFilter(lang: 'es' | 'en') {
      let visibleCount = 0;

      projectEntryNodes.forEach((node) => {
        const projectTagIds = parseTagIds(node);
        const matchesFilter = !selectedTagId || projectTagIds.includes(selectedTagId);

        node.classList.toggle('hidden', !matchesFilter);
        if (matchesFilter) visibleCount += 1;
      });

      tagFilterButtons.forEach((button) => {
        const isActive = selectedTagId === (button.dataset.tagId ?? '');
        button.setAttribute('aria-pressed', isActive ? 'true' : 'false');
        button.classList.toggle('!bg-white', isActive);
        button.classList.toggle('!text-black', isActive);
      });

      if (emptyStateNode) {
        emptyStateNode.textContent = FILTER_COPY[lang].empty;
        const shouldShowEmpty = Boolean(selectedTagId) && visibleCount === 0;
        emptyStateNode.classList.toggle('hidden', !shouldShowEmpty);
      }

      updateActiveFilter(lang);
    }

    function setSelectedTag(tagId: string | null, lang: 'es' | 'en') {
      selectedTagId = tagId;
      applyProjectFilter(lang);
    }

    function applyMyProjectsLanguage(lang: 'es' | 'en') {
      currentLang = lang;
      const dictionary = MYPROJECTS_I18N[lang];

      i18nNodes.forEach((node) => {
        const key = node.dataset.i18nMyprojects as keyof typeof dictionary | undefined;
        if (!key) return;
        node.textContent = dictionary[key];
      });

      projectTitleNodes.forEach((node) => {
        const localizedTitle = node.getAttribute(`data-${lang}`)?.trim();
        node.textContent = localizedTitle || (lang === 'en' ? 'Project' : 'Proyecto');
      });

      projectDescriptionNodes.forEach((node) => {
        const localizedDescription = node.getAttribute(`data-${lang}`)?.trim();
        node.textContent = localizedDescription || '';
      });

      projectTagsNodes.forEach((node) => {
        const localizedTags = parseLocalizedList(node, lang);

        node.innerHTML = '';
        localizedTags.forEach((tag: string) => {
          const tagNode = document.createElement('span');
          tagNode.className = 'chip';
          tagNode.textContent = tag;
          node.appendChild(tagNode);
        });
      });

      projectLinkNodes.forEach((node) => {
        const localizedLabel = node.getAttribute(`data-${lang}`)?.trim();
        node.textContent = localizedLabel || (lang === 'en' ? 'View link' : 'Ver enlace');
      });

      tagFilterButtons.forEach((button) => {
        button.textContent = getTagLabel(button, lang);
      });

      applyProjectFilter(lang);
    }

    tagFilterButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const clickedTagId = button.dataset.tagId ?? null;
        if (!clickedTagId) return;
        setSelectedTag(clickedTagId, currentLang);
      });
    });

    tagFilterResetButton?.addEventListener('click', () => {
      setSelectedTag(null, currentLang);
    });

    const initialLang = sanitizeLang(localStorage.getItem(LANG_STORAGE_KEY));
    applyMyProjectsLanguage(initialLang);

    window.addEventListener('site-language-change', (event) => {
      const customEvent = event as CustomEvent<{ lang?: string }>;
      applyMyProjectsLanguage(sanitizeLang(customEvent.detail?.lang ?? null));
    });
  }

  document.addEventListener('astro:page-load', initMyProjectsLanguage);
  initMyProjectsLanguage();
</script>