---
import Layout from '../../layouts/Layout.astro';
import "../../styles/global.css";
import { sanityClient } from '../../lib/sanity'
import YouTube from "../../components/Youtube.astro";
import Footer from '../../components/Footer.astro';
import { DEFAULT_LANG, LANG_STORAGE_KEY } from '../../i18n/translations';
import { urlFor } from "../../lib/sanityImageUrl";

type SanityImage = {
  alt?: string
  crop?: {
    _type?: string
    top?: number
    bottom?: number
    left?: number
    right?: number
  }
  hotspot?: {
    _type?: string
    x?: number
    y?: number
    height?: number
    width?: number
  }
  asset?: {
    _ref?: string
    _type?: "reference"
  }
}

type LocalizedText = {
  es?: string
  en?: string
}

type SanityTag = {
  label?: LocalizedText
}

type LocalizedContentBlock = {
  texto?: LocalizedText
  imagenes?: SanityImage[]
}

type LocalizedTecnicasBlock = LocalizedContentBlock & {
  tags?: (SanityTag | null)[]
}

type ProjectRaw = {
  titulo?: LocalizedText
  slug?: {
    current?: string
  }
  descripcioncorta?: LocalizedText
  anio?: number
  tags?: (SanityTag | null)[]
  imagencover?: SanityImage
  links?: ({ label?: LocalizedText; url?: string } | null)[]
  youtubeLinks?: (string | null)[]
  introduccion?: LocalizedContentBlock
  tecnicas?: LocalizedTecnicasBlock
  mensaje?: LocalizedContentBlock
  inspiracion?: LocalizedContentBlock
  intencion?: LocalizedContentBlock
  informacionRecalcable?: LocalizedText
}

type ProjectContentBlock = {
  texto?: string
  textoEs?: string
  textoEn?: string
  imagenes?: SanityImage[]
}

type ProjectTecnicasBlock = ProjectContentBlock & {
  tags?: string[]
  tagsEs?: string[]
  tagsEn?: string[]
}

type ProjectMapped = {
  titulo?: string
  tituloEs?: string
  tituloEn?: string
  slug?: {
    current?: string
  }
  anio?: number
  tags?: string[]
  tagsEs?: string[]
  tagsEn?: string[]
  imagencover?: SanityImage
  links?: { label?: string; labelEs?: string; labelEn?: string; url?: string }[]
  youtubeIds?: string[]
  introduccion?: ProjectContentBlock
  tecnicas?: ProjectTecnicasBlock
  mensaje?: ProjectContentBlock
  inspiracion?: ProjectContentBlock
  intencion?: ProjectContentBlock
  informacionRecalcable?: string
  informacionRecalcableEs?: string
  informacionRecalcableEn?: string
}

export async function getStaticPaths() {
  const projects = await sanityClient.fetch<Array<{ slug?: { current?: string } }>>(`
    *[_type == "proyecto"][]{
      slug
    }
  `)

  return projects
    .map((project) => {
      const slug = project.slug?.current ?? ''

      if (!slug) {
        return null
      }

      return {
        params: { slug },
      }
    })
    .filter((path): path is { params: { slug: string } } => Boolean(path))
}

const { slug } = Astro.params

const defaultLang = DEFAULT_LANG;

const pickLocalized = (value: LocalizedText | undefined, lang: 'es' | 'en') => {
  if (!value) return '';
  return lang === 'en' ? value.en ?? value.es ?? '' : value.es ?? value.en ?? '';
}

const mapLocalizedBlock = (block: LocalizedContentBlock | undefined): ProjectContentBlock | undefined => {
  if (!block) return undefined;
  return {
    texto: pickLocalized(block.texto, defaultLang),
    textoEs: pickLocalized(block.texto, 'es'),
    textoEn: pickLocalized(block.texto, 'en'),
    imagenes: block.imagenes,
  };
}

const getLocalizedTags = (tags: (SanityTag | null)[] | undefined, lang: 'es' | 'en') =>
  (tags ?? [])
    .map((tag) => {
      if (!tag?.label) return '';
      return lang === 'en'
        ? tag.label.en ?? tag.label.es ?? ''
        : tag.label.es ?? tag.label.en ?? '';
    })
    .filter(Boolean)

const mapLocalizedLinks = (links: ({ label?: LocalizedText; url?: string } | null)[] | undefined) =>
  (links ?? [])
    .filter((link): link is { label?: LocalizedText; url?: string } => Boolean(link?.url))
    .map((link) => ({
      label: pickLocalized(link.label, defaultLang),
      labelEs: pickLocalized(link.label, 'es') || 'Ver enlace',
      labelEn: pickLocalized(link.label, 'en') || 'View link',
      url: link.url,
    }))

const extractYouTubeId = (value: string | null | undefined): string | undefined => {
  if (!value) return undefined;
  const input = value.trim();
  if (!input) return undefined;

  const directIdPattern = /^[A-Za-z0-9_-]{11}$/;
  if (directIdPattern.test(input)) {
    return input;
  }

  try {
    const url = new URL(input);
    const host = url.hostname.replace(/^www\./i, '').toLowerCase();

    if (host === 'youtu.be') {
      const idFromPath = url.pathname.split('/').filter(Boolean)[0];
      return directIdPattern.test(idFromPath ?? '') ? idFromPath : undefined;
    }

    if (host === 'youtube.com' || host === 'm.youtube.com' || host === 'music.youtube.com') {
      const idFromQuery = url.searchParams.get('v');
      if (directIdPattern.test(idFromQuery ?? '')) {
        return idFromQuery ?? undefined;
      }

      const pathParts = url.pathname.split('/').filter(Boolean);
      const lastPart = pathParts[pathParts.length - 1];
      if ((pathParts[0] === 'embed' || pathParts[0] === 'shorts') && directIdPattern.test(lastPart ?? '')) {
        return lastPart;
      }
    }
  } catch {
    return undefined;
  }

  return undefined;
}

const projectRaw = await sanityClient.fetch<ProjectRaw | null>(
  `*[_type == "proyecto" && slug.current == $slug][0]{
    titulo{es,en},
    slug,
    descripcioncorta{es,en},
    anio,
    tags[]->{
      label{es,en}
    },

    imagencover{
    ...,
    crop,
    hotspot,
    asset
    },

    links[]{
      label{es,en},
      url
    },

    youtubeLinks,

    introduccion{
      texto{es,en},
      imagenes[]{
        ...,
        crop,
        hotspot,
        asset
      }
    },

    tecnicas{
      texto{es,en},
      tags[]->{
        label{es,en}
      },
      imagenes[]{
        ...,
        crop,
        hotspot,
        asset
      }
    },

    mensaje{
      texto{es,en},
      imagenes[]{
        ...,
       crop,
  hotspot,
  asset
      }
    },

    inspiracion{
      texto{es,en},
      imagenes[]{
        ...,
          crop,
  hotspot,
  asset
      }
    },

    intencion{
      texto{es,en},
      imagenes[]{
        ...,
        crop,
  hotspot,
  asset
      }
    },

    informacionRecalcable{es,en}
  }`,
  { slug }
)

const project: ProjectMapped | null = projectRaw
  ? {
      titulo: pickLocalized(projectRaw.titulo, defaultLang),
      tituloEs: pickLocalized(projectRaw.titulo, 'es'),
      tituloEn: pickLocalized(projectRaw.titulo, 'en'),
      slug: projectRaw.slug,
      anio: projectRaw.anio,
      tags: getLocalizedTags(projectRaw.tags, defaultLang),
      tagsEs: getLocalizedTags(projectRaw.tags, 'es'),
      tagsEn: getLocalizedTags(projectRaw.tags, 'en'),
      imagencover: projectRaw.imagencover,
      links: mapLocalizedLinks(projectRaw.links),
      youtubeIds: (projectRaw.youtubeLinks ?? [])
        .map(extractYouTubeId)
        .filter((id): id is string => Boolean(id))
        .slice(0, 4),
      introduccion: mapLocalizedBlock(projectRaw.introduccion),
      tecnicas: {
        ...mapLocalizedBlock(projectRaw.tecnicas),
        tags: getLocalizedTags(projectRaw.tecnicas?.tags, defaultLang),
        tagsEs: getLocalizedTags(projectRaw.tecnicas?.tags, 'es'),
        tagsEn: getLocalizedTags(projectRaw.tecnicas?.tags, 'en'),
      },
      mensaje: mapLocalizedBlock(projectRaw.mensaje),
      inspiracion: mapLocalizedBlock(projectRaw.inspiracion),
      intencion: mapLocalizedBlock(projectRaw.intencion),
      informacionRecalcable: pickLocalized(projectRaw.informacionRecalcable, defaultLang),
      informacionRecalcableEs: pickLocalized(projectRaw.informacionRecalcable, 'es'),
      informacionRecalcableEn: pickLocalized(projectRaw.informacionRecalcable, 'en'),
    }
  : null;

const imageUrl = (image?: SanityImage) =>
  image?.asset?._ref
    ? urlFor(image).width(1100).format("webp").quality(80).url()
    : undefined;

const sectionTitles = {
  tecnicas: { es: 'Tecnicas', en: 'Techniques' },
  mensaje: { es: 'Mensaje', en: 'Message' },
  inspiracion: { es: 'Inspiracion', en: 'Inspiration' },
  intencion: { es: 'Intencion', en: 'Intention' },
  informacionRecalcable: { es: 'Informacion recalcable', en: 'Highlighted information' },
};

const optionalSections: Array<{
  key: string
  title: string
  titleEs: string
  titleEn: string
  data?: ProjectContentBlock | ProjectTecnicasBlock
}> = [
  {
    key: 'tecnicas',
    title: defaultLang === 'en' ? sectionTitles.tecnicas.en : sectionTitles.tecnicas.es,
    titleEs: sectionTitles.tecnicas.es,
    titleEn: sectionTitles.tecnicas.en,
    data: project?.tecnicas,
  },
  {
    key: 'mensaje',
    title: defaultLang === 'en' ? sectionTitles.mensaje.en : sectionTitles.mensaje.es,
    titleEs: sectionTitles.mensaje.es,
    titleEn: sectionTitles.mensaje.en,
    data: project?.mensaje,
  },
  {
    key: 'inspiracion',
    title: defaultLang === 'en' ? sectionTitles.inspiracion.en : sectionTitles.inspiracion.es,
    titleEs: sectionTitles.inspiracion.es,
    titleEn: sectionTitles.inspiracion.en,
    data: project?.inspiracion,
  },
  {
    key: 'intencion',
    title: defaultLang === 'en' ? sectionTitles.intencion.en : sectionTitles.intencion.es,
    titleEs: sectionTitles.intencion.es,
    titleEn: sectionTitles.intencion.en,
    data: project?.intencion,
  },
].filter((section) => {
  const hasText = Boolean(section.data?.textoEs || section.data?.textoEn)
  const hasImages = Boolean(section.data?.imagenes?.length)
  const hasTags =
    section.key === 'tecnicas' &&
    Boolean((section.data as ProjectTecnicasBlock | undefined)?.tagsEs?.length || (section.data as ProjectTecnicasBlock | undefined)?.tagsEn?.length)

  return hasText || hasImages || hasTags
})

---

<Layout>
      <section

    aria-label="Sección principal"
      id="proyectos"
        style="margin: 0 auto; width: 100%; max-width: 1800px; "
  class="px-6 sm:px-12 lg:px-24 pb-20"
  >

  {project ? (
    <article class="project-entry" aria-label={project.titulo}>
 
      <!-- ── TOP ROW: título + cover ── -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-start mb-4">
 
        <!-- Left: título + meta -->
        <div class="flex flex-col gap-5">
 
          <!-- Título + chevron -->
          <div class="flex items-center gap-4">
            <h2 class="font-manrope font-black  leading-none text-neutral-100
                       text-[clamp(2.8rem,7vw,5rem)] uppercase"
                data-i18n-project-text
                data-es={project.tituloEs ?? ''}
                data-en={project.tituloEn ?? ''}
            >
              {project.titulo}
            </h2>
            <!-- Chevron down -->
            {/* <svg
              xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
              class="project-chevron w-8 h-8 sm:w-10 sm:h-10 text-neutral-400 shrink-0 mt-1"
              aria-hidden="true"
            >
              <path d="m6 9 6 6 6-6"/>
            </svg> */}
          </div>
 
          <!-- Category chips -->
          <div
            class="flex flex-wrap gap-2"
            data-i18n-project-tags
            data-tag-class="chip"
            data-es={JSON.stringify(project.tagsEs ?? [])}
            data-en={JSON.stringify(project.tagsEn ?? [])}
          >
            {project.tags?.map((tag) => (
              <span class="chip">{tag}</span>
            ))}
          </div>
 
          <!-- Introducción (obligatoria) -->
          <div class="mt-1">
            <p class=" text-lg text-neutral-400 leading-relaxed">
              <span
                data-i18n-project-text
                data-es={project.introduccion?.textoEs ?? ''}
                data-en={project.introduccion?.textoEn ?? ''}
              >
                {project.introduccion?.texto}
              </span>
            </p>
          </div>
 
          <div class="mt-2 flex flex-wrap gap-2">
            <span>{project.anio}</span>
          </div>

          {project.links && project.links.length > 0 && (
            <div class="mt-2 flex flex-wrap gap-2">
              {project.links.map((link) => (
                <a
                  href={link.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="chip"
                >
                  <span
                    data-i18n-project-text
                    data-es={link.labelEs ?? 'Ver enlace'}
                    data-en={link.labelEn ?? 'View link'}
                  >
                    {link.label ?? 'Ver enlace'}
                  </span>
                </a>
              ))}
            </div>
          )}
 
        </div>
 
        <!-- Right: cover image -->
        <div class="project-img-wrap rounded-2xl overflow-hidden bg-[#191a1a]
                     ">
          {imageUrl(project.imagencover) ? (
            <img
              src={imageUrl(project.imagencover)}
              alt={defaultLang === 'en' ? `Cover image of ${project.titulo}` : `Imagen de portada de ${project.titulo}`}
              class="w-full h-auto object-contain"
              loading="lazy"
            />
          ) : (
            <div class="project-img-placeholder flex items-center justify-center h-full">
              
            </div>
          )}
        </div>
 
      </div>
      <!-- /TOP ROW -->
 
      <!-- ── INTRODUCCIÓN (obligatoria en schema) ── -->
      {(project.introduccion?.texto || project.introduccion?.imagenes?.length) && (
        <div class="project-gallery mt-0">
          {project.introduccion?.imagenes && project.introduccion.imagenes.length > 0 && (
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
              {project.introduccion.imagenes.map((image, imageIdx) => (
                <div
                  class:list={[
                    'project-img-wrap h-fit  rounded-2xl overflow-hidden bg-[#191a1a] ',
                    imageIdx === 0 && project.introduccion?.imagenes && project.introduccion.imagenes.length > 1
                      ? 'sm:col-span-2 '
                      : ''
                  ]}
                >
                  {imageUrl(image) ? (
                    <img
                      src={imageUrl(image)}
                      alt={defaultLang === 'en' ? `Introduction image of ${project.titulo}` : `Imagen de introduccion de ${project.titulo}`}
                      class="w-full h-auto object-cover"
                      loading="lazy"
                    />
                  ) : (
                    <div class="project-img-placeholder flex items-center justify-center h-full">
                      <span
                        class=" text-[10px] uppercase tracking-widest text-neutral-600"
                        data-i18n-project-text
                        data-es="Imagen no disponible"
                        data-en="Image unavailable"
                      >
                        {defaultLang === 'en' ? 'Image unavailable' : 'Imagen no disponible'}
                      </span>
                    </div>
                  )}
                </div>
              ))}
            </div>
          )}
        </div>
      )}

      {project.youtubeIds && project.youtubeIds.length > 0 && (
        <div class="project-gallery mt-6">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
            {project.youtubeIds.map((youtubeId, videoIdx) => (
              <div
                class:list={[
                  project.youtubeIds && project.youtubeIds.length === 3 && videoIdx === 2
                    ? 'sm:col-span-2'
                    : ''
                ]}
              >
                <YouTube
                  id={youtubeId}
                  title={defaultLang === 'en'
                    ? `YouTube video ${videoIdx + 1} of ${project.titulo}`
                    : `Video de YouTube ${videoIdx + 1} de ${project.titulo}`}
                />
              </div>
            ))}
          </div>
        </div>
      )}

      <!-- ── BLOQUES OPCIONALES ── -->
      {optionalSections.map((section) => (
        <div class="project-gallery mt-40" id={section.key}>
          <div class="mb-14">
            <h3
              class="text-2xl text-neutral-500 uppercase tracking-widest mb-2"
              data-i18n-project-text
              data-es={section.titleEs}
              data-en={section.titleEn}
            >
              {section.title}
            </h3>
            {section.data?.texto && (
              <p class=" text-lg text-neutral-400 leading-relaxed">
                <span
                  data-i18n-project-text
                  data-es={section.data.textoEs ?? ''}
                  data-en={section.data.textoEn ?? ''}
                >
                  {section.data.texto}
                </span>
              </p>
            )}

            {section.key === 'tecnicas' && (section.data as ProjectTecnicasBlock)?.tags && (
              <div
                class="mt-3 flex flex-wrap gap-2"
                data-i18n-project-tags
                data-tag-class="chip"
                data-es={JSON.stringify((section.data as ProjectTecnicasBlock).tagsEs ?? [])}
                data-en={JSON.stringify((section.data as ProjectTecnicasBlock).tagsEn ?? [])}
              >
                {(section.data as ProjectTecnicasBlock).tags?.map((tag) => (
                  <span class="chip">{tag}</span>
                ))}
              </div>
            )}
          </div>

          {section.data?.imagenes && section.data.imagenes.length > 0 && (
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
              {section.data.imagenes.map((image, imageIdx) => (
                <div
                  class:list={[
                    'project-img-wrap  h-fit  rounded-2xl overflow-hidden bg-[#191a1a] ',
                    section.key !== 'intencion' && imageIdx === 0 && section.data?.imagenes && section.data.imagenes.length > 1
                      ? 'sm:col-span-2 '
                      : ''
                  ]}
                >
                  {imageUrl(image) ? (
                    <img
                      src={imageUrl(image)}
                      alt={defaultLang === 'en' ? `Image of ${section.titleEn.toLowerCase()} from ${project.titulo}` : `Imagen de ${section.title.toLowerCase()} de ${project.titulo}`}
                      class="w-full h-auto object-cover"
                      loading="lazy"
                    />
                  ) : (
                    <div class="project-img-placeholder flex items-center justify-center h-full">
                      <span
                        class=" text-[10px] uppercase tracking-widest text-neutral-600"
                        data-i18n-project-text
                        data-es="Imagen no disponible"
                        data-en="Image unavailable"
                      >
                        {defaultLang === 'en' ? 'Image unavailable' : 'Imagen no disponible'}
                      </span>
                    </div>
                  )}
                </div>
              ))}
            </div>
          )}
        </div>
      ))}

      {project.informacionRecalcable && (
        <div class="project-gallery mt-10">
          <p
            class=" text-neutral-500 uppercase tracking-widest mb-2"
            data-i18n-project-text
            data-es={sectionTitles.informacionRecalcable.es}
            data-en={sectionTitles.informacionRecalcable.en}
          >
            {defaultLang === 'en' ? sectionTitles.informacionRecalcable.en : sectionTitles.informacionRecalcable.es}
          </p>
          <p class=" text-lg text-neutral-400 leading-relaxed">
            <span
              data-i18n-project-text
              data-es={project.informacionRecalcableEs ?? ''}
              data-en={project.informacionRecalcableEn ?? ''}
            >
              {project.informacionRecalcable}
            </span>
          </p>
        </div>
      )}
 
    </article>
  ) : (
    <article class="project-entry">
      <p
        class=" text-lg text-neutral-400"
        data-i18n-project-text
        data-es="Proyecto no encontrado."
        data-en="Project not found."
      >
        {defaultLang === 'en' ? 'Project not found.' : 'Proyecto no encontrado.'}
      </p>
    </article>
  )}
 
</section>
<Footer/>
</Layout>

<script>
  import { LANG_STORAGE_KEY } from '../../i18n/translations';

  function initProjectLanguage() {
    const textNodes = Array.from(
      document.querySelectorAll<HTMLElement>('[data-i18n-project-text]'),
    );
    const tagNodes = Array.from(
      document.querySelectorAll<HTMLElement>('[data-i18n-project-tags]'),
    );

    function sanitizeLang(value: string | null): 'es' | 'en' {
      return value === 'en' ? 'en' : 'es';
    }

    function parseLocalizedList(node: HTMLElement, lang: 'es' | 'en') {
      const raw = node.getAttribute(`data-${lang}`) ?? '[]';

      try {
        const parsed = JSON.parse(raw);
        if (!Array.isArray(parsed)) return [];
        return parsed.filter((item): item is string => typeof item === 'string');
      } catch {
        return [];
      }
    }

    function applyProjectLanguage(lang: 'es' | 'en') {
      textNodes.forEach((node) => {
        const localizedText = node.getAttribute(`data-${lang}`)?.trim();
        if (!localizedText) return;
        node.textContent = localizedText;
      });

      tagNodes.forEach((node) => {
        const localizedTags = parseLocalizedList(node, lang);
        const tags = localizedTags.length > 0 ? localizedTags : "";
        const tagClass = node.getAttribute('data-tag-class') ?? 'chip';

        node.innerHTML = '';
        tags.forEach((tag) => {
          const tagNode = document.createElement('span');
          tagNode.className = tagClass;
          tagNode.textContent = tag;
          node.appendChild(tagNode);
        });
      });
    }

    const initialLang = sanitizeLang(localStorage.getItem(LANG_STORAGE_KEY));
    applyProjectLanguage(initialLang);

    window.addEventListener('site-language-change', (event) => {
      const customEvent = event as CustomEvent<{ lang?: string }>;
      applyProjectLanguage(sanitizeLang(customEvent.detail?.lang ?? null));
    });
  }

  document.addEventListener('astro:page-load', initProjectLanguage);
  initProjectLanguage();
</script>