---
import { LANG_STORAGE_KEY, translations } from "../i18n/translations";
---

<a
  href="/myproyects"
  class="go-back-to-projects"
  data-i18n-goback="backToProjects"
  aria-label="Volver a proyectos">Volver a proyectos</a
>

<script>
  const LANG_STORAGE_KEY = "site-lang";
  const GO_BACK_I18N = {
    es: "Volver a proyectos",
    en: "Back to projects",
  };

  function sanitizeLang(value) {
    return value === "en" ? "en" : "es";
  }

  function applyGoBackLanguage(lang) {
    const node = document.querySelector("[data-i18n-goback]");
    if (!node) return;
    node.textContent = GO_BACK_I18N[lang];
    node.setAttribute("aria-label", GO_BACK_I18N[lang]);
  }

  function initGoBackLanguage() {
    const initialLang = sanitizeLang(localStorage.getItem(LANG_STORAGE_KEY));
    applyGoBackLanguage(initialLang);
    window.addEventListener("site-language-change", (event) => {
      const customEvent = event;
      applyGoBackLanguage(sanitizeLang(customEvent.detail?.lang ?? null));
    });
  }

  document.addEventListener("astro:page-load", initGoBackLanguage);
  initGoBackLanguage();
</script>

<style>
  .go-back-to-projects {
    position: fixed;
    height: 64px;
    left: 50%;
    bottom: 4rem;
    transform: translateX(-50%);
    border: 1px solid rgba(255, 255, 255, 0.28);
    border-radius: 9999px;
    background: #1f2020;
    color: #ffffff;
    font-size: 0.95rem;
    font-weight: 600;
    line-height: 1;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.9rem 1.5rem;
    box-shadow: 0 10px 28px rgba(0, 0, 0, 0.34);
    backdrop-filter: blur(5px);
    -webkit-backdrop-filter: blur(5px);
    opacity: 0.78;
    transition:
      opacity 220ms ease,
      transform 220ms ease,
      border-color 220ms ease,
      background-color 220ms ease;
    z-index: 140;
  }

  .go-back-to-projects:hover,
  .go-back-to-projects:focus-visible {
    opacity: 1;
    border-color: rgba(255, 255, 255, 0.55);
    background: rgba(24, 24, 24, 0.88);
  }

  .go-back-to-projects:focus-visible {
    outline: 2px solid rgba(255, 255, 255, 0.8);
    outline-offset: 2px;
  }

  @media (max-width: 640px) {
    .go-back-to-projects {
      bottom: 4rem;
      height: 48px;
      font-size: 0.88rem;
      padding: 0.8rem 1.2rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .go-back-to-projects {
      transition: none;
    }
  }
</style>
