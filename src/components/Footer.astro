---
// Footer.astro
// src/components/Footer.astro

const year = new Date().getFullYear();

const links = [
  { label: "Privacy", href: "/privacy" },
  { label: "Terms",   href: "/terms"   },
  { label: "Cookies", href: "/cookies" },
];
---

<footer class="border-t border-white/[0.1] w-full mx-auto max-w-[1800px]">
  <div class="max-w-[1200px] mx-auto px-6 sm:px-12 lg:px-24 py-12
              flex flex-col sm:flex-row items-center justify-between gap-4">

    <!-- Copyright -->
    <p class="font-inter text-xs text-neutral-600 tracking-wide">
      © {year} Sandra Guillén
    </p>

    <!-- Legal links -->
    <nav aria-label="Legal">
      <ul class="flex items-center gap-6 list-none m-0 p-0">
        {links.map((l) => (
          <li>
            <a
              href={l.href}
              class="font-inter text-xs text-neutral-600 hover:text-neutral-400
                     transition-colors duration-200 tracking-wide"
            >
              {l.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

  </div>
</footer>