---
// Footer.astro
// src/components/Footer.astro
import {
  DEFAULT_LANG,
  LANG_STORAGE_KEY,
  translations,
} from "../i18n/translations";
import { sanityClient } from "../lib/sanity";
import logo from "./../../public/images/SANDRA GUILLEN.svg";

const year = new Date().getFullYear();
const defaultLang = DEFAULT_LANG;

const perfil = await sanityClient.fetch(`
  *[_type == "perfil"][0]{
    descripcioncorta{
      es,
      en
    },
  }
`);

const descripcionCortaEs =
  perfil?.descripcioncorta?.es ?? perfil?.descripcioncorta?.en ?? "";
const descripcionCortaEn =
  perfil?.descripcioncorta?.en ?? perfil?.descripcioncorta?.es ?? "";
---

<footer class="px-6 sm:px-12 lg:px-24 pb-10 w-full mx-auto max-w-450">
  <div class="px-6 py-10 sm:px-10 sm:py-12">
    <div
      class="grid grid-cols-1 gap-10 md:grid-cols-[minmax(0,1fr)_auto] md:gap-16"
    >
      <div class="flex flex-col items-start gap-6">
        <a href="/" aria-label="Ir al inicio" class="inline-flex">
          <img src={logo.src} alt="Sandra Guillén" class="w-24 sm:w-28" />
        </a>

        <p
          id="footer-descripcion-corta"
          class="max-w-[34ch] text-sm leading-relaxed text-neutral-300"
          data-es={descripcionCortaEs}
          data-en={descripcionCortaEn}
        >
          {defaultLang === "es" ? descripcionCortaEs : descripcionCortaEn}
        </p>

        <div class="flex items-center gap-3" aria-label="Redes sociales">
          <a
            href="https://www.linkedin.com/in/sandra-guillen/"
            target="_blank"
            rel="noopener noreferrer"
            class="footer-social"
            aria-label="LinkedIn"
            title="LinkedIn"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="currentColor"
              class="w-6 h-6"
              aria-hidden="true"
            >
              <path
                d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136
                         1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85
                         3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062
                         2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782
                         13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0
                         1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24
                         23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
              ></path>
            </svg>
          </a>

          <a
            href="https://www.instagram.com/"
            target="_blank"
            rel="noopener noreferrer"
            class="footer-social"
            aria-label="Instagram"
            title="Instagram"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="currentColor"
              class="w-6 h-6"
              aria-hidden="true"
            >
              <path
                d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691
                         4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012
                         3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204
                         0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849
                         0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057
                         1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273
                         2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072
                         4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12
                         24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618
                         6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014
                         15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0
                         0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44
                         1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"
              ></path>
            </svg>
          </a>
        </div>
      </div>

      <nav class="justify-self-start md:justify-self-end" aria-label="Footer">
        <ul class="flex flex-col gap-3 text-2xl leading-none sm:text-3xl">
          <li>
            <a
              href="/"
              class="footer-link hover:text-white"
              data-i18n-footer="home">Inicio</a
            >
          </li>
          <li>
            <a
              href="/myproyects"
              class="footer-link hover:text-white"
              data-i18n-footer="projects">Proyectos</a
            >
          </li>
          <li>
            <a
              href="/proyecto/illustrations"
              class="footer-link hover:text-white"
              data-i18n-footer="ilustrations">Ilustraciones</a
            >
          </li>
          <li>
            <a
              href="/proyecto/photograph"
              class="footer-link hover:text-white"
              data-i18n-footer="photografies">Fotografías</a
            >
          </li>
          <li>
            <a
              href="https://www.linkedin.com/in/sandra-guillen/"
              target="_blank"
              rel="noopener noreferrer"
              class="footer-link hover:text-white"
              data-i18n-footer="contact">¿Hablamos?</a
            >
          </li>
        </ul>
      </nav>
    </div>

    <div
      class="mt-10 border-t border-white/12 pt-5 flex flex-col gap-3 text-sm text-neutral-500 sm:flex-row sm:items-center sm:justify-between"
    >
      <div class="flex items-center gap-5">
        <p>
          <span data-i18n-footer="createdBy"
            >{translations[defaultLang].general.createdBy}</span
          >
          <span> </span>
          <a
            href="https://www.linkedin.com/in/javierrocap"
            target="_blank"
            rel="noopener noreferrer"
            class="underline underline-offset-2 decoration-neutral-500 hover:text-neutral-300 transition-colors duration-200"
          >
            Javierrocadev
          </a>
        </p>
      </div>
      <p>© Sandra Guillén {year}</p>
    </div>
  </div>
</footer>

<script>
  import { LANG_STORAGE_KEY, translations } from "../i18n/translations";

  const FOOTER_I18N = {
    es: {
      ...translations.es.general,
      ...translations.es.nav,
      mission: "Diseño y narrativa visual para comunicar ideas con intención.",
    },
    en: {
      ...translations.en.general,
      ...translations.en.nav,
      mission:
        "Design and visual storytelling to communicate ideas with intention.",
    },
  };

  function initFooterLanguage() {
    const i18nNodes = Array.from(
      document.querySelectorAll("[data-i18n-footer]"),
    );
    const descripcionNode = document.getElementById("footer-descripcion-corta");

    function sanitizeLang(value) {
      return value === "en" ? "en" : "es";
    }

    function applyFooterLanguage(lang) {
      const dictionary = FOOTER_I18N[lang];
      i18nNodes.forEach((node) => {
        const key = node.dataset.i18nFooter;
        if (!key) return;
        node.textContent = dictionary[key];
      });
      if (descripcionNode) {
        const text =
          descripcionNode.getAttribute(`data-${lang}`) ||
          descripcionNode.getAttribute("data-es") ||
          "";
        descripcionNode.textContent = text;
      }
    }

    const initialLang = sanitizeLang(localStorage.getItem(LANG_STORAGE_KEY));
    applyFooterLanguage(initialLang);

    window.addEventListener("site-language-change", (event) => {
      const customEvent = event;
      applyFooterLanguage(sanitizeLang(customEvent.detail?.lang ?? null));
    });
  }

  document.addEventListener("astro:page-load", initFooterLanguage);
  initFooterLanguage();
</script>
