---
import { sanityClient } from "../lib/sanity";
import { DEFAULT_LANG, translations } from "../i18n/translations";

const perfil = await sanityClient.fetch(`
  *[_type == "perfil"][0]{
    nombre,
    ocupacion{
      es,
      en
    },
    descripcioncorta{
      es,
      en
    },
    tags,
    avatar
  }
`);

const defaultLang = DEFAULT_LANG;
const heroDictionary = translations;
const ocupacionEs = perfil?.ocupacion?.es ?? perfil?.ocupacion?.en ?? "";
const ocupacionEn = perfil?.ocupacion?.en ?? perfil?.ocupacion?.es ?? "";
const descripcionCortaEs =
  perfil?.descripcioncorta?.es ?? perfil?.descripcioncorta?.en ?? "";
const descripcionCortaEn =
  perfil?.descripcioncorta?.en ?? perfil?.descripcioncorta?.es ?? "";
---

<!-- ───────────────────────────────────────────
       HERO SECTION
       ─────────────────────────────────────────── -->
<section
  id="particles-js"
  class="hero-section relative min-h-screen flex flex-col justify-center bg-surface px-6 sm:px-12 lg:px-24"
  aria-label="Sección principal"
>
  <!-- Content wrapper — offset left for asymmetric rhythm -->
  <div class="relative z-10 max-w-5xl w-full pb-4">
    <!-- Chip / Label pill -->
    <div
      class="inline-flex items-center px-4 py-1.5 rounded-full border border-white/10 mb-10
               text-[11px] font-inter font-medium uppercase text-neutral-400
               animate-fade-up delay-1"
      aria-label="Especialidad"
      id="hero-ocupacion"
      data-es={ocupacionEs}
      data-en={ocupacionEn}
    >
      {defaultLang === "es" ? ocupacionEs : ocupacionEn}
    </div>

    <!-- Display headline -->
    <!-- "Diseñar con" — bold sans -->
    <!-- "un propósito" — italic serif accent on the keyword -->
    <h1
      class="font-bold text-neutral-200 leading-[1.03]
               text-[clamp(3rem,8vw,6rem)]
               animate-fade-up delay-2"
      id="hero-title"
    >
      <span
        id="hero-title-line1"
        data-title-es={heroDictionary.es.hero.title}
        data-title-en={heroDictionary.en.hero.title}
      >
        {heroDictionary[defaultLang].hero.title}
      </span><br />
      <span
        id="hero-title-line2"
        data-title-es={heroDictionary.es.hero.title2}
        data-title-en={heroDictionary.en.hero.title2}
      >
        {heroDictionary[defaultLang].hero.title2}
      </span>
    </h1>

    <!-- Sub-copy — appears at a larger desktop breakpoint -->
    <p
      class="mt-4 max-w-md font-inter text-base leading-relaxed text-neutral-400
                 animate-fade-up delay-3"
      id="hero-descripcion-corta"
      data-es={descripcionCortaEs}
      data-en={descripcionCortaEn}
    >
      {defaultLang === "es" ? descripcionCortaEs : descripcionCortaEn}
    </p>

    <!-- CTA buttons -->
    <div
      class="mt-12 mb-32 flex flex-wrap items-center gap-4 animate-fade-up delay-4"
    >
      <!-- Primary -->
      <a
        href="/myproyects"
        class="inline-flex items-center gap-2 px-8 py-3 rounded-full
                 bg-neutral-100 text-black font-manrope font-semibold text-sm
                 transition-all duration-300 hover:bg-white hover:-translate-y-px"
      >
        <span data-i18n-hero="viewProjects">
          {heroDictionary[defaultLang].hero.viewProjects}
        </span>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 20 20"
          fill="currentColor"
          class="w-4 h-4"
        >
          <path
            fill-rule="evenodd"
            d="M3 10a.75.75 0 0 1 .75-.75h10.638L10.23 5.29a.75.75 0 1 1 1.04-1.08l5.5 5.25a.75.75 0 0 1 0 1.08l-5.5 5.25a.75.75 0 1 1-1.04-1.08l4.158-3.96H3.75A.75.75 0 0 1 3 10Z"
            clip-rule="evenodd"></path>
        </svg>
      </a>

      <!-- Ghost -->
      <a
        href="#contacto"
        class="inline-flex items-center gap-2 px-8 py-3 rounded-full
                 border border-white/20 text-neutral-300 font-manrope font-medium text-sm
                 transition-all duration-300 hover:bg-white/5 hover:border-white/30"
      >
        <span data-i18n-hero="contact">
          {heroDictionary[defaultLang].hero.contact}
        </span>
      </a>
    </div>
  </div>
  <!-- /content wrapper -->

  <!-- Decorative large ghost text — editorial depth element -->
  <span
    aria-hidden="true"
    class="absolute right-10 top-180 md:top-190 lg:top-180 xl:top-180 2xl:top-180 lg:bottom-6 font-manrope font-bold text-[clamp(6rem,14vw,16rem)]
             leading-none text-white/2.5 select-none pointer-events-none
             translate-x-8 lg:translate-x-0 text-right"
  >
    Sandra Guillén
  </span>
</section>

<!-- /hero -->
<script>
  import { LANG_STORAGE_KEY, translations } from "../i18n/translations";
  const HERO_I18N = {
    es: translations.es.hero,
    en: translations.en.hero,
  };

  function initHeroLanguage() {
    const ocupacionNode = document.getElementById("hero-ocupacion");
    const descripcionNode = document.getElementById("hero-descripcion-corta");
    const titleLine1Node = document.getElementById("hero-title-line1");
    const titleLine2Node = document.getElementById("hero-title-line2");
    const heroI18nNodes = Array.from(
      document.querySelectorAll<HTMLElement>("[data-i18n-hero]"),
    );

    if (
      !ocupacionNode ||
      !descripcionNode ||
      !titleLine1Node ||
      !titleLine2Node
    )
      return;
    const ocupacionElement = ocupacionNode;
    const descripcionElement = descripcionNode;
    const titleLine1Element = titleLine1Node;
    const titleLine2Element = titleLine2Node;

    function sanitizeLang(value: string | null): "es" | "en" {
      return value === "en" ? "en" : "es";
    }

    function applyHeroLanguage(lang: "es" | "en") {
      const dictionary = HERO_I18N[lang];
      const ocupacionText =
        ocupacionElement.getAttribute(`data-${lang}`) ??
        ocupacionElement.getAttribute("data-es") ??
        "";
      const descripcionText =
        descripcionElement.getAttribute(`data-${lang}`) ??
        descripcionElement.getAttribute("data-es") ??
        "";

      ocupacionElement.textContent = ocupacionText;
      descripcionElement.textContent = descripcionText;

      const titleLine1 =
        titleLine1Element.getAttribute(`data-title-${lang}`) ??
        titleLine1Element.getAttribute("data-title-es") ??
        "";
      const titleLine2 =
        titleLine2Element.getAttribute(`data-title-${lang}`) ??
        titleLine2Element.getAttribute("data-title-es") ??
        "";
      titleLine1Element.textContent = titleLine1;
      titleLine2Element.textContent = titleLine2;

      heroI18nNodes.forEach((node) => {
        const key = node.dataset.i18nHero as
          | keyof typeof dictionary
          | undefined;
        if (!key) return;
        node.textContent = dictionary[key];
      });
    }

    const initialLang = sanitizeLang(localStorage.getItem(LANG_STORAGE_KEY));
    applyHeroLanguage(initialLang);

    window.addEventListener("site-language-change", (event) => {
      const customEvent = event as CustomEvent<{ lang?: string }>;
      applyHeroLanguage(sanitizeLang(customEvent.detail?.lang ?? null));
    });
  }

  document.addEventListener("astro:page-load", initHeroLanguage);
  initHeroLanguage();
</script>
<style>
  canvas {
    display: block;
    vertical-align: bottom;
  }

  /* ---- particles.js container ---- */

  #particles-js {
  }
</style>
