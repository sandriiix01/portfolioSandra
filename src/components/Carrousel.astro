---
import { sanityClient } from "../lib/sanity";
import { DEFAULT_LANG, translations } from "../i18n/translations";

type GalleryImage = {
  alt?: string;
  asset?: {
    url?: string;
  };
};

type GalleryRaw = {
  _id: string;
  titulo?: string;
  tituloEn?: string;
  imagenes?: GalleryImage[];
};

type SliderItem = {
  url: string;
  alt: string;
  tituloEs: string;
  tituloEn: string;
  href: string;
};

const [illustrationsRaw, photographsRaw] = await Promise.all([
  sanityClient.fetch<GalleryRaw[]>(`
    *[_type == "ilustraciones"]{
      _id,
      titulo,
      tituloEn,
      imagenes[]{
        alt,
        asset->{
          url
        }
      }
    }
  `),
  sanityClient.fetch<GalleryRaw[]>(`
    *[_type == "fotografias"]{
      _id,
      titulo,
      tituloEn,
      imagenes[]{
        alt,
        asset->{
          url
        }
      }
    }
  `),
]);

const shuffleItems = <T,>(items: T[]): T[] => {
  const shuffled = [...items];
  for (let index = shuffled.length - 1; index > 0; index -= 1) {
    const randomIndex = Math.floor(Math.random() * (index + 1));
    [shuffled[index], shuffled[randomIndex]] = [
      shuffled[randomIndex],
      shuffled[index],
    ];
  }
  return shuffled;
};

const createSectionId = (title: string, id: string): string => {
  const normalizedTitle = title
    .toLowerCase()
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "");

  const safeTitle = normalizedTitle || "seccion";
  const safeIdSuffix = id.slice(-6);
  return `${safeTitle}-${safeIdSuffix}`;
};

const mapGalleryToSliderItems = (
  galleries: GalleryRaw[],
  hrefBase: string,
): SliderItem[] => {
  const groupedItems = galleries.flatMap((gallery) => {
    const validImages = (gallery.imagenes ?? []).filter((image) =>
      Boolean(image?.asset?.url),
    );

    const randomImages = shuffleItems(validImages).slice(0, 3);
    const tituloEs = gallery.titulo ?? "Sin titulo";
    const tituloEn = gallery.tituloEn ?? gallery.titulo ?? "Untitled";
    const sectionId = createSectionId(gallery.titulo ?? tituloEn, gallery._id);

    return randomImages.map((image) => ({
      url: image.asset?.url ?? "",
      alt: image.alt ?? tituloEs,
      tituloEs,
      tituloEn,
      href: `${hrefBase}#${sectionId}`,
    }));
  });

  return shuffleItems(groupedItems);
};

const sliderItemsIllustrations = mapGalleryToSliderItems(
  illustrationsRaw,
  "/proyecto/illustrations",
);

const sliderItemsPhotographies = mapGalleryToSliderItems(
  photographsRaw,
  "/proyecto/photograph",
);

const defaultLang = DEFAULT_LANG;
const carouselDictionary = translations;
---

<link
  rel="stylesheet"
  href="https://cdn.jsdelivr.net/npm/keen-slider@6.8.6/keen-slider.min.css"
/>

<div
  style="margin: 0 auto; width: 100%; max-width: 1800px;"
  class="px-6 sm:px-12 lg:px-24"
>
  <section class="w-full py-20 flex flex-col gap-16">
    <!-- Header -->

    <!-- Carousels -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <div>
        <h2
          data-i18n-carousel="ilustrations"
          class="text-white text-3xl md:text-4xl leading-tight mb-12"
        >
          {carouselDictionary[defaultLang].general.ilustrations}
        </h2>
        <article
          class="rounded-2xl border border-white/10 bg-white/5 p-4 sm:p-6"
        >
          <div class="mb-4 flex items-center justify-end gap-2.5">
            <button
              id="arrow-left-1"
              aria-label="Anterior"
              class="arrow text-white cursor-pointer border border-white/20 rounded-full w-10 h-10 flex items-center justify-center hover:border-white/35 hover:bg-white/8 transition-colors duration-200"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><polyline points="15 18 9 12 15 6"></polyline></svg
              >
            </button>
            <button
              id="arrow-right-1"
              aria-label="Siguiente"
              class="arrow text-white cursor-pointer border border-white/20 rounded-full w-10 h-10 flex items-center justify-center hover:border-white/35 hover:bg-white/8 transition-colors duration-200"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><polyline points="9 18 15 12 9 6"></polyline></svg
              >
            </button>
          </div>

          <div class="overflow-hidden mx-auto">
            <div id="keen-slider-1" class="keen-slider h-120 max-h-120">
              <!-- Slides inyectados por JS -->
            </div>
          </div>
        </article>
      </div>
      <div>
        <h2
          data-i18n-carousel="photografies"
          class="text-white text-3xl md:text-4xl leading-tight mb-12"
        >
          {carouselDictionary[defaultLang].general.photografies}
        </h2>
        <article
          class="rounded-2xl border border-white/10 bg-white/5 p-4 sm:p-6"
        >
          <div class="mb-4 flex items-center justify-end gap-2.5">
            <button
              id="arrow-left-2"
              aria-label="Anterior"
              class="arrow text-white cursor-pointer border border-white/20 rounded-full w-10 h-10 flex items-center justify-center hover:border-white/35 hover:bg-white/8 transition-colors duration-200"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><polyline points="15 18 9 12 15 6"></polyline></svg
              >
            </button>
            <button
              id="arrow-right-2"
              aria-label="Siguiente"
              class="arrow text-white cursor-pointer border border-white/20 rounded-full w-10 h-10 flex items-center justify-center hover:border-white/35 hover:bg-white/8 transition-colors duration-200"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><polyline points="9 18 15 12 9 6"></polyline></svg
              >
            </button>
          </div>

          <div class="overflow-hidden mx-auto">
            <div id="keen-slider-2" class="keen-slider h-120 max-h-120">
              <!-- Slides inyectados por JS -->
            </div>
          </div>
        </article>
      </div>
    </div>
  </section>
</div>

<script
  type="module"
  define:vars={{ sliderItemsIllustrations, sliderItemsPhotographies }}
>
  import KeenSlider from "https://cdn.jsdelivr.net/npm/keen-slider@6.8.6/+esm";

  const carouselWindow = window;

  const slidesDataIllustrations = Array.isArray(sliderItemsIllustrations)
    ? sliderItemsIllustrations
    : [];
  const slidesDataPhotographies = Array.isArray(sliderItemsPhotographies)
    ? sliderItemsPhotographies
    : [];
  const languageStorageKey = "site-lang";

  const sanitizeLang = (value) => (value === "en" ? "en" : "es");
  let currentLang = sanitizeLang(localStorage.getItem(languageStorageKey));

  const createSlides = (items, lang) =>
    items
      .map(
        (item) => `
      <div class="keen-slider__slide h-full px-2 sm:px-3 overflow-visible flex">
        <a
          href="${item.href || "#"}"
         
          class="h-full w-full overflow-hidden group block rounded-xl border border-white/10 bg-black/20 flex flex-col"
        >
          <div class="relative overflow-hidden flex-1 min-h-0 flex items-center justify-center bg-black/25">
            <img
              src="${item.url}"
              alt="${item.alt}"
              class="w-full h-full object-contain object-center transition-transform duration-300 group-hover:scale-[1.03]"
              loading="lazy"
            />
            <div class="absolute inset-0 flex items-center justify-center bg-black/0 opacity-0 transition-all duration-300 group-hover:bg-black/35 group-hover:opacity-100">
              <span class="text-sm md:text-base font-bold text-white tracking-wide">
                ${lang === "en" ? `See ${item.tituloEn}` : `Ver ${item.tituloEs}`}
              </span>
            </div>
          </div>
          <div class="border-t border-white/10 px-3 py-2 text-sm text-white/80 shrink-0">
            ${lang === "en" ? item.tituloEn : item.tituloEs}
          </div>
        </a>
      </div>
    `,
      )
      .join("");

  const autoLoop =
    (delay = 2000) =>
    (slider) => {
      let timeout;
      let mouseOver = false;

      const clearNextTimeout = () => {
        clearTimeout(timeout);
      };

      const nextTimeout = () => {
        clearTimeout(timeout);
        if (mouseOver) return;
        timeout = setTimeout(() => {
          slider.next();
        }, delay);
      };

      slider.on("created", () => {
        slider.container.addEventListener("mouseover", () => {
          mouseOver = true;
          clearNextTimeout();
        });
        slider.container.addEventListener("mouseout", () => {
          mouseOver = false;
          nextTimeout();
        });
        nextTimeout();
      });

      slider.on("dragStarted", clearNextTimeout);
      slider.on("animationEnded", nextTimeout);
      slider.on("updated", nextTimeout);
    };

  const initCarousel = (sliderId, leftArrowId, rightArrowId, slidesData) => {
    const sliderElement = document.getElementById(sliderId);
    const arrowLeft = document.getElementById(leftArrowId);
    const arrowRight = document.getElementById(rightArrowId);

    if (!sliderElement || slidesData.length === 0) return null;

    sliderElement.innerHTML = createSlides(slidesData, currentLang);

    const slider = new KeenSlider(
      sliderElement,
      {
        loop: true,
        drag: true,
        slides: {
          perView: 1,
          spacing: 12,
        },
        breakpoints: {
          "(min-width: 768px)": {
            slides: { perView: 1, spacing: 14 },
          },
          "(min-width: 1200px)": {
            slides: { perView: 1, spacing: 16 },
          },
        },
      },
      [autoLoop(2000)],
    );

    const onPrev = () => slider.prev();
    const onNext = () => slider.next();

    if (arrowLeft) {
      arrowLeft.addEventListener("click", onPrev);
    }

    if (arrowRight) {
      arrowRight.addEventListener("click", onNext);
    }

    return () => {
      arrowLeft?.removeEventListener("click", onPrev);
      arrowRight?.removeEventListener("click", onNext);
      slider.destroy();
      sliderElement.innerHTML = "";
    };
  };

  const initCarousels = () => {
    if (typeof carouselWindow.__carouselCleanup === "function") {
      carouselWindow.__carouselCleanup();
    }

    const cleanups = [
      initCarousel(
        "keen-slider-1",
        "arrow-left-1",
        "arrow-right-1",
        slidesDataIllustrations,
      ),
      initCarousel(
        "keen-slider-2",
        "arrow-left-2",
        "arrow-right-2",
        slidesDataPhotographies,
      ),
    ].filter((cleanup) => typeof cleanup === "function");

    carouselWindow.__carouselCleanup = () => {
      cleanups.forEach((cleanup) => {
        if (typeof cleanup === "function") cleanup();
      });
    };
  };

  document.addEventListener("astro:page-load", initCarousels);
  window.addEventListener("site-language-change", (event) => {
    const customEvent = event;
    currentLang = sanitizeLang(customEvent?.detail?.lang ?? null);
    initCarousels();
  });
  initCarousels();
</script>

<script>
  import { LANG_STORAGE_KEY, translations } from "../i18n/translations";

  const CAROUSEL_I18N = {
    es: translations.es.general,
    en: translations.en.general,
  };

  function initCarouselLanguage() {
    const i18nNodes = Array.from(
      document.querySelectorAll<HTMLElement>("[data-i18n-carousel]"),
    );

    function sanitizeLang(value: string | null): "es" | "en" {
      return value === "en" ? "en" : "es";
    }

    function applyCarouselLanguage(lang: "es" | "en") {
      const dictionary = CAROUSEL_I18N[lang];

      i18nNodes.forEach((node) => {
        const key = node.dataset.i18nCarousel as
          | keyof typeof dictionary
          | undefined;
        if (!key) return;
        node.textContent = dictionary[key];
      });
    }

    const initialLang = sanitizeLang(localStorage.getItem(LANG_STORAGE_KEY));
    applyCarouselLanguage(initialLang);

    window.addEventListener("site-language-change", (event) => {
      const customEvent = event as CustomEvent<{ lang?: string }>;
      applyCarouselLanguage(sanitizeLang(customEvent.detail?.lang ?? null));
    });
  }

  document.addEventListener("astro:page-load", initCarouselLanguage);
  initCarouselLanguage();
</script>
