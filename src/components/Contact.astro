---
import { DEFAULT_LANG, LANG_STORAGE_KEY, translations } from "../i18n/translations";

const email = "sandraguillenmarcos@gmail.com";
const defaultLang = DEFAULT_LANG;
const dictionary = translations;

const socials = [
  {
    name: "LinkedIn",
    handle: "Sandra Guillén",
    href: "https://www.linkedin.com/in/sandra-guillen/",
    icon: "linkedin",
  },
  {
    name: "Instagram",
    handle: "@siirxdelta",
    href: "https://instagram.com/siirxdelta",
    icon: "instagram",
  },
];
---

<section
  id="contacto"
  class="relative flex flex-col items-center text-center px-6 py-28 sm:py-36 overflow-hidden"
  aria-label={dictionary[defaultLang].general.talk}
  data-i18n-contact-aria-label="talk"
>

  <!-- Decorative ghost text backdrop -->
  <span
    data-i18n-contact="talk"
    aria-hidden="true"
    class="contact-ghost-text pointer-events-none select-none absolute inset-0 flex items-center justify-center
           font-manrope font-black text-white leading-none tracking-tighter"
  >
    {dictionary[defaultLang].general.talk}
  </span>

  <!-- Content: sits above the ghost text -->
  <div class="relative z-10 flex flex-col items-center gap-8 w-full max-w-xl">

    <!-- Headline -->
    <h2
      data-i18n-contact="talk"
      class="font-manrope font-black tracking-tighter leading-[0.95] text-neutral-100
             text-[clamp(2.5rem,8vw,6rem)]"
    >
      {dictionary[defaultLang].general.talk}
    </h2>

    <!-- Subtext -->
    <p class="font-inter text-sm text-neutral-400 leading-relaxed -mt-2" data-i18n-contact="subtalk">
      {dictionary[defaultLang].general.subtalk}
    </p>

    <!-- Email pill -->
    <a
      href={`mailto:${email}`}
      class="group flex items-center gap-3 px-6 py-3.5 rounded-full
             bg-[#1f2020] border border-white/10
             font-inter text-sm text-neutral-300
             transition-all duration-300 hover:border-white/25 hover:bg-[#252626] hover:text-white"
      aria-label={`Enviar email a ${email}`}
    >
      {email}
      <!-- Arrow icon -->
      <svg
        xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor"
        class="w-3.5 h-3.5 text-neutral-500 group-hover:text-neutral-300 transition-colors duration-300"
        aria-hidden="true"
      >
        <path fill-rule="evenodd"
          d="M4.22 11.78a.75.75 0 0 1 0-1.06L9.44 5.5H5.75a.75.75 0 0 1 0-1.5h5.5a.75.75 0 0 1 .75.75v5.5a.75.75 0 0 1-1.5 0V6.56l-5.22 5.22a.75.75 0 0 1-1.06 0Z"
          clip-rule="evenodd"
        />
      </svg>
    </a>

    <!-- Social cards -->
    <div class="flex gap-3 w-full justify-center flex-wrap">
      {socials.map((s) => (
        <a
          href={s.href}
          target="_blank"
          rel="noopener noreferrer"
          class="group flex flex-col items-start gap-3 p-5 rounded-2xl
               bg-[#1f2020] border border-white/6
                 
               transition-all duration-300 hover:border-white/15 hover:bg-[#252626] min-w-50"
          aria-label={`${s.name}: ${s.handle}`}
        >
          <!-- Icon -->
          <span class="text-neutral-400 group-hover:text-neutral-200 transition-colors duration-300">
            {s.icon === "linkedin" && (
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"
                   class="w-6 h-6" aria-hidden="true">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136
                         1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85
                         3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062
                         2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782
                         13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0
                         1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24
                         23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            )}
            {s.icon === "instagram" && (
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"
                   class="w-6 h-6" aria-hidden="true">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691
                         4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012
                         3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204
                         0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849
                         0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057
                         1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273
                         2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072
                         4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12
                         24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618
                         6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014
                         15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0
                         0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44
                         1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>
              </svg>
            )}
          </span>

          <!-- Text -->
          <span class="flex flex-col items-start gap-0.5 text-left">
            <span class="font-manrope font-semibold text-sm text-neutral-200 group-hover:text-white transition-colors duration-300">
              {s.name}
            </span>
            <span class="font-inter text-xs text-neutral-500 leading-snug break-all">
              {s.handle}
            </span>
          </span>
        </a>
      ))}
    </div>

  </div>
</section>

<script>
  import { LANG_STORAGE_KEY, translations } from "../i18n/translations";

  const CONTACT_I18N = {
    es: translations.es.general,
    en: translations.en.general,
  };

  function initContactLanguage() {
    const i18nNodes = Array.from(
      document.querySelectorAll<HTMLElement>("[data-i18n-contact]"),
    );
    const i18nAriaNodes = Array.from(
      document.querySelectorAll<HTMLElement>("[data-i18n-contact-aria-label]"),
    );

    function sanitizeLang(value: string | null): "es" | "en" {
      return value === "en" ? "en" : "es";
    }

    function applyContactLanguage(lang: "es" | "en") {
      const dictionary = CONTACT_I18N[lang];

      i18nNodes.forEach((node) => {
        const key = node.dataset.i18nContact as keyof typeof dictionary | undefined;
        if (!key) return;
        node.textContent = dictionary[key];
      });

      i18nAriaNodes.forEach((node) => {
        const key = node.dataset.i18nContactAriaLabel as
          | keyof typeof dictionary
          | undefined;
        if (!key) return;
        node.setAttribute("aria-label", dictionary[key]);
      });
    }

    const initialLang = sanitizeLang(localStorage.getItem(LANG_STORAGE_KEY));
    applyContactLanguage(initialLang);

    window.addEventListener("site-language-change", (event) => {
      const customEvent = event as CustomEvent<{ lang?: string }>;
      applyContactLanguage(sanitizeLang(customEvent.detail?.lang ?? null));
    });
  }

  document.addEventListener("astro:page-load", initContactLanguage);
  initContactLanguage();
</script>