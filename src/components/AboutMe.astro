---
import { sanityClient } from "../lib/sanity";
import {
  DEFAULT_LANG,
  LANG_STORAGE_KEY,
  translations,
} from "../i18n/translations";
import { urlFor } from "../lib/sanityImageUrl";

type PerfilProgram = {
  nombre?: string;
  nivel?: number;
};

type Perfil = {
  nombre?: string;
  descripcion?: {
    es?: string;
    en?: string;
  };
  cv?: {
    asset?: {
      url?: string;
      originalFilename?: string;
    };
  };
  cvEn?: {
    asset?: {
      url?: string;
      originalFilename?: string;
    };
  };
  avatar?: {
    crop?: {
      _type?: string;
      top?: number;
      bottom?: number;
      left?: number;
      right?: number;
    };
    hotspot?: {
      _type?: string;
      x?: number;
      y?: number;
      height?: number;
      width?: number;
    };
    asset?: {
      _ref?: string;
      _type?: "reference";
    };
  };
  programas?: PerfilProgram[];
};

const perfil = await sanityClient.fetch<Perfil | null>(`
  *[_type == "perfil"][0]{
    nombre,
    cv{
      asset->{
        url,
        originalFilename
      }
    },
    cvEn{
      asset->{
        url,
        originalFilename
      }
    },
    descripcion{
      es,
      en
    },
    avatar{
      crop,
      hotspot,
      asset
    },
    programas[]{
      nombre,
      nivel
    }
  }
`);

const cvUrl = perfil?.cv?.asset?.url;
const cvFilename = perfil?.cv?.asset?.originalFilename ?? "cv.pdf";
const cvEnUrl = perfil?.cvEn?.asset?.url;
const cvEnFilename = perfil?.cvEn?.asset?.originalFilename ?? "cv-en.pdf";
const avatarUrl = perfil?.avatar?.asset?._ref
  ? urlFor(perfil.avatar).width(500).format("webp").quality(80).url()
  : null;
const profileName = perfil?.nombre ?? "Sandra Guillen Marcos";

const programs = (perfil?.programas ?? []).map((program) => ({
  name: program.nombre ?? "Programa",
  level: Math.min(Math.max(Math.round(program.nivel ?? 0), 0), 5),
}));

const aboutParagraphsEs = (perfil?.descripcion?.es ?? "")
  .split("\n")
  .map((line) => line.trim())
  .filter(Boolean);

const aboutParagraphsEn = (
  perfil?.descripcion?.en ??
  perfil?.descripcion?.es ??
  ""
)
  .split("\n")
  .map((line) => line.trim())
  .filter(Boolean);

const defaultLang = DEFAULT_LANG;
const aboutDictionary = translations;
const aboutParagraphs =
  defaultLang === "en" ? aboutParagraphsEn : aboutParagraphsEs;

const MAX_STARS = 5;
---

<div
  style="margin: 0 auto; width: 100%; max-width: 1800px; "
  class="px-6 sm:px-12 lg:px-24 py-20"
>
  <section class="about-section" id="sobre-mi" aria-label="Sobre mí">
    <!-- ── Top label chip ── -->
    <div class="about-chip-wrap">
      <span class="chip" data-i18n-about="aboutMe">
        {aboutDictionary[defaultLang].general.aboutMe}
      </span>
    </div>

    <!-- ── Display headline ── -->
    <h2 class="about-headline">Sandra Guillén Marcos</h2>

    <!-- ── Two-column body ── -->
    <div class="about-grid">
      <!-- LEFT: Bio -->
      <div class="about-bio">
        <h3 class="about-bio__title" data-i18n-about="aboutMe">
          {aboutDictionary[defaultLang].general.aboutMe}
        </h3>

        <div
          id="about-bio-text"
          class="about-bio__text"
          data-es={JSON.stringify(aboutParagraphsEs)}
          data-en={JSON.stringify(aboutParagraphsEn)}
        >
          {
            aboutParagraphs.length > 0 ? (
              aboutParagraphs.map((paragraph) => <p>{paragraph}</p>)
            ) : (
              <p data-i18n-about="noDescription">
                {aboutDictionary[defaultLang].general.noDescription}
              </p>
            )
          }
        </div>

        <div class="about-cv-actions">
          {
            cvUrl ? (
              <a
                href={cvUrl}
                download={cvFilename}
                target="_blank"
                rel="noopener noreferrer"
                class="group flex items-center gap-3 px-6 py-3.5 rounded-full
             bg-[#1f2020] border border-white/10
             font-inter text-sm text-neutral-300
             transition-all duration-300 hover:border-white/25 hover:bg-[#252626] hover:text-white"
                data-i18n-about="downloadCV"
              >
                {aboutDictionary[defaultLang].general.downloadCV}
              </a>
            ) : null
          }

          {
            cvEnUrl ? (
              <a
                href={cvEnUrl}
                download={cvEnFilename}
                target="_blank"
                rel="noopener noreferrer"
                class="group flex items-center gap-3 px-6 py-3.5 rounded-full
             bg-[#1f2020] border border-white/10
             font-inter text-sm text-neutral-300
             transition-all duration-300 hover:border-white/25 hover:bg-[#252626] hover:text-white"
                data-i18n-about="downloadCVEn"
              >
                {aboutDictionary[defaultLang].general.downloadCVEn}
              </a>
            ) : null
          }
        </div>

        {
          avatarUrl ? (
            <figure class="about-avatar-wrap">
              <img
                src={avatarUrl}
                alt={profileName}
                class="about-avatar"
                loading="lazy"
                decoding="async"
              />
            </figure>
          ) : null
        }
      </div>

      <!-- RIGHT: Programs & skill ratings -->
      <div class="about-skills">
        <h3 class="about-skills__title" data-i18n-about="programs">
          {aboutDictionary[defaultLang].general.programs}
        </h3>

        <ul
          class="skills-list"
          role="list"
          aria-label={aboutDictionary[defaultLang].general.programsLevelAria}
          data-i18n-about-aria-label="programsLevelAria"
        >
          {
            programs.length > 0 ? (
              programs.map((prog) => (
                <li class="skills-row">
                  <span class="skills-row__name">{prog.name}</span>
                  <span class="sr-only">
                    {`Nivel ${prog.level} de ${MAX_STARS}`}
                  </span>
                  <span class="skills-row__stars" aria-hidden="true">
                    {Array.from({ length: MAX_STARS }).map((_, i) => (
                      <svg
                        class:list={[
                          "star-icon",
                          i < prog.level
                            ? "star-icon--filled"
                            : "star-icon--empty",
                        ]}
                        xmlns="http://www.w3.org/2000/svg"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                        aria-hidden="true"
                      >
                        {/* 4-pointed star / sparkle */}
                        <path d="M12 2 L13.5 10.5 L22 12 L13.5 13.5 L12 22 L10.5 13.5 L2 12 L10.5 10.5 Z" />
                      </svg>
                    ))}
                  </span>
                </li>
              ))
            ) : (
              <li class="skills-row">
                <span class="skills-row__name" data-i18n-about="noPrograms">
                  {aboutDictionary[defaultLang].general.noPrograms}
                </span>
              </li>
            )
          }
        </ul>
      </div>
    </div><!-- /about-grid -->
  </section>
</div>

<script>
  import { LANG_STORAGE_KEY, translations } from "../i18n/translations";

  const ABOUT_I18N = {
    es: translations.es.general,
    en: translations.en.general,
  };

  function initAboutLanguage() {
    const i18nNodes = Array.from(
      document.querySelectorAll<HTMLElement>("[data-i18n-about]"),
    );
    const i18nAriaNodes = Array.from(
      document.querySelectorAll<HTMLElement>("[data-i18n-about-aria-label]"),
    );
    const bioNode = document.getElementById("about-bio-text");

    function sanitizeLang(value: string | null): "es" | "en" {
      return value === "en" ? "en" : "es";
    }

    function renderBioParagraphs(
      lang: "es" | "en",
      dictionary: typeof ABOUT_I18N.es,
    ) {
      if (!bioNode) return;

      const raw = bioNode.getAttribute(`data-${lang}`) ?? "[]";
      let paragraphs: string[] = [];

      try {
        const parsed = JSON.parse(raw);
        if (Array.isArray(parsed)) {
          paragraphs = parsed.filter(
            (item): item is string => typeof item === "string",
          );
        }
      } catch {
        paragraphs = [];
      }

      bioNode.innerHTML = "";

      if (paragraphs.length === 0) {
        const paragraph = document.createElement("p");
        paragraph.textContent = dictionary.noDescription;
        bioNode.appendChild(paragraph);
        return;
      }

      paragraphs.forEach((text) => {
        const paragraph = document.createElement("p");
        paragraph.textContent = text;
        bioNode.appendChild(paragraph);
      });
    }

    function applyAboutLanguage(lang: "es" | "en") {
      const dictionary = ABOUT_I18N[lang];

      i18nNodes.forEach((node) => {
        const key = node.dataset.i18nAbout as
          | keyof typeof dictionary
          | undefined;
        if (!key) return;
        node.textContent = dictionary[key];
      });

      i18nAriaNodes.forEach((node) => {
        const key = node.dataset.i18nAboutAriaLabel as
          | keyof typeof dictionary
          | undefined;
        if (!key) return;
        node.setAttribute("aria-label", dictionary[key]);
      });

      renderBioParagraphs(lang, dictionary);
    }

    const initialLang = sanitizeLang(localStorage.getItem(LANG_STORAGE_KEY));
    applyAboutLanguage(initialLang);

    window.addEventListener("site-language-change", (event) => {
      const customEvent = event as CustomEvent<{ lang?: string }>;
      applyAboutLanguage(sanitizeLang(customEvent.detail?.lang ?? null));
    });
  }

  document.addEventListener("astro:page-load", initAboutLanguage);
  initAboutLanguage();
</script>
