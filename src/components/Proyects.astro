---
import { sanityClient } from "../lib/sanity";
import { DEFAULT_LANG, translations } from "../i18n/translations";
import { urlFor } from "../lib/sanityImageUrl";

type LocalizedText = {
  es?: string;
  en?: string;
};

type ProjectTag = {
  label?: LocalizedText;
};

type ProjectLink = {
  label?: LocalizedText;
  url?: string;
};

type ProjectImage = {
  url?: string;
  alt?: string;
  titulo?: string;
  tituloEs?: string;
  tituloEn?: string;
  descripcion?: string;
  tags?: string[];
  tagsEs?: string[];
  tagsEn?: string[];
  links?: ProjectLink[];
  slug?: { current?: string };
};

type SanityProject = {
  titulo?: LocalizedText;
  descripcioncorta?: LocalizedText;
  tags?: (ProjectTag | null)[];
  links?: (ProjectLink | null)[];
  slug?: { current?: string };
  imagencover?: {
    alt?: string;
    crop?: {
      _type?: string;
      top?: number;
      bottom?: number;
      left?: number;
      right?: number;
    };
    hotspot?: {
      _type?: string;
      x?: number;
      y?: number;
      height?: number;
      width?: number;
    };
    asset?: {
      _ref?: string;
      _type?: "reference";
    };
  };
};

const defaultLang: "es" | "en" = DEFAULT_LANG;

const pickLocalized = (value: LocalizedText | undefined, lang: "es" | "en") => {
  if (!value) return "";
  return lang === "en"
    ? (value.en ?? value.es ?? "")
    : (value.es ?? value.en ?? "");
};

const getLocalizedTags = (
  tags: (ProjectTag | null)[] | undefined,
  lang: "es" | "en",
) =>
  (tags ?? [])
    .map((tag) => {
      if (!tag?.label) return "";
      return lang === "en"
        ? (tag.label.en ?? tag.label.es ?? "")
        : (tag.label.es ?? tag.label.en ?? "");
    })
    .filter(Boolean);

const getSafeLinks = (links: (ProjectLink | null)[] | undefined) =>
  (links ?? []).filter((link): link is ProjectLink => Boolean(link));

const proyects = await sanityClient.fetch<SanityProject[]>(`
*[_type == "proyecto" && destacado == true][0..4]{
  titulo{es,en},
  descripcioncorta{es,en},
  tags[]->{
    label{es,en}
  },
  links[]{
    label{es,en},
    url
  },
  slug,
  imagencover{
    alt,
    crop,
    hotspot,
    asset
  },
}
`);

const projectImages: ProjectImage[] = proyects
  .flatMap((project) =>
    (project.imagencover ? [project.imagencover] : []).map((image) => ({
      url: image?.asset?._ref
        ? urlFor(image).width(800).format("webp").quality(80).url()
        : "",
      alt: image?.alt,
      titulo: pickLocalized(project.titulo, defaultLang),
      tituloEs: pickLocalized(project.titulo, "es"),
      tituloEn: pickLocalized(project.titulo, "en"),
      descripcion: pickLocalized(project.descripcioncorta, defaultLang),
      tagsEs: getLocalizedTags(project.tags, "es"),
      tagsEn: getLocalizedTags(project.tags, "en"),
      tags: getLocalizedTags(project.tags, defaultLang),
      links: getSafeLinks(project.links),
      slug: project.slug,
    })),
  )
  .filter((image: ProjectImage) => Boolean(image.url));

const gridImages = Array.from(
  { length: 5 },
  (_, index) => projectImages[index] ?? null,
);

const grid1Slots = [
  { baseColor: "bg-gray-300", image: gridImages[0] },
  { baseColor: "bg-gray-400", image: gridImages[1] },
  { baseColor: "bg-gray-500", image: gridImages[2] },
];

const grid2Slots = [
  { baseColor: "bg-gray-300", image: gridImages[3] },
  { baseColor: "bg-gray-400", image: gridImages[4] },
  { baseColor: "", image: null, isExplore: true },
];

const getProjectHref = (slug?: { current?: string }) =>
  slug?.current ? `/proyecto/${slug.current}` : "#";

const projectsDictionary = translations;
const fallbackProjectLabel = pickLocalized(
  { es: "Proyecto", en: "Project" },
  defaultLang,
);
const fallbackProjectImageAlt = pickLocalized(
  { es: "Imagen de proyecto", en: "Project image" },
  defaultLang,
);
---

