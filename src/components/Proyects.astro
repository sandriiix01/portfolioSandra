                    class="absolute bottom-6 left-6 text-white  text-4xl font-normal"
                    data-i18n-project-title
                    data-es={slot.image.tituloEs ?? ""}
                    data-en={slot.image.tituloEn ?? ""}
                  >
                    {slot.image.titulo ?? fallbackProjectLabel}
                  </h3>
                </a>
              )}
            </div>
          ))
        }
      </div>

      <!-- GRID 2 (cortes diferentes) -->
      <div class="flex flex-col flex-1 gap-4">
        {
          grid2Slots.map((slot) => (
            <div
              class={`${slot.baseColor} relative overflow-hidden rounded-2xl`}
            >
              {slot.isExplore && (
                // <div class="h-full w-full flex flex-col items-start justify-between rounded-2xl border border-white/10 p-8">
                //   <h3 class="text-white  text-4xl font-normal">
                //     Explorar
                //   </h3>
                //   <a
                //     href="#proyectos"
                //     class="inline-flex items-center gap-2 px-8 py-3 rounded-full bg-neutral-100 text-black font-manrope font-semibold text-sm transition-all duration-300 hover:bg-white hover:-translate-y-px"
                //   >
                //     Ver mas
                //     <svg
                //       xmlns="http://www.w3.org/2000/svg"
                //       viewBox="0 0 20 20"
                //       fill="currentColor"
                //       class="w-4 h-4"
                //     >
                //       <path
