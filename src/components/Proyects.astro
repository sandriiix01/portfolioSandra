---
import imagen1 from '../../public/images/imagen1.webp';
import { sanityClient } from '../lib/sanity'

const perfil = await sanityClient.fetch(`
  *[_type == "perfil"][0]{
    nombre,
    ocupacion,
    descripcion,
    tags,
    avatar
  }
`)
---
<div title='Sandra'>


			<div style="margin: 0 auto; width: 100%; max-width: 1800px; padding: 2rem;" class="">
  <section class=" w-full py-20 flex flex-col gap-16 px-8">

    <!-- Header -->
    <div class="flex flex-col gap-4">
      <span class="w-fit bg-white/5 border border-white/10 rounded-full px-4 py-1 text-white/60 text-xs uppercase tracking-[3.6px]">
        Selected Works
      </span>
      <h2 class="text-white font-['Instrument_Serif'] text-6xl md:text-8xl leading-tight">
        Featured <span class="text-transparent">Projects</span>
      </h2>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">

      <!-- Large card - spans 2 cols on lg -->
      <div class="lg:col-span-2 lg:row-span-2  rounded-2xl overflow-hidden relative group duration-300 ease-in-out">
        <img src={imagen1.src} class="w-full h-full object-cover min-h-64" />
      
  <div class="absolute inset-0 bg-gradient-to-r from-black/92 via-black/60 to-black/20 opacity-30 transition-opacity duration-500 group-hover:opacity-100"></div>
   <div class="absolute top-6 left-6 flex flex-col gap-1 opacity-0 translate-y-2.5 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-400">
          <span class="text-white/60 text-[11px] uppercase tracking-[2.5px]">Architecture</span>
          <span class="text-white text-sm">2024</span>
        </div>
        <h3 class="absolute bottom-6 left-6 text-white font-['Instrument_Serif'] text-4xl font-normal">Minimal Architecture</h3>
      </div>

      <!-- Small cards -->
      <div class="bg-stone-950 rounded-2xl overflow-hidden relative">
        <img src="data:image/jpeg;base64," class="w-full h-64 object-cover" />
        <div class="absolute inset-0 bg-gradient-to-r from-black via-black/40 to-transparent opacity-80"></div>
        <div class="absolute bottom-6 left-6">
          <h3 class="text-white font-['Instrument_Serif'] text-3xl">Luxury Brand</h3>
        </div>
      </div>

      <div class="bg-stone-950 rounded-2xl overflow-hidden relative">
        <img src="https://placehold.co/403x450" class="w-full h-64 object-cover" />
        <div class="absolute inset-0 bg-gradient-to-r from-black via-black/40 to-transparent opacity-80"></div>
        <div class="absolute bottom-6 left-6">
          <h3 class="text-white font-['Instrument_Serif'] text-3xl">Tech Interface</h3>
        </div>
      </div>

      <div class="bg-stone-950 rounded-2xl overflow-hidden relative">
        <img src="https://placehold.co/403x450" class="w-full h-64 object-cover" />
        <div class="absolute inset-0 bg-gradient-to-r from-black via-black/40 to-transparent opacity-80"></div>
        <div class="absolute bottom-6 left-6">
          <h3 class="text-white font-['Instrument_Serif'] text-3xl">Product Photography</h3>
        </div>
      </div>

      <div class="bg-stone-950 rounded-2xl overflow-hidden relative">
        <img src="https://placehold.co/403x450" class="w-full h-64 object-cover" />
        <div class="absolute inset-0 bg-gradient-to-r from-black via-black/40 to-transparent opacity-80"></div>
        <div class="absolute bottom-6 left-6">
          <h3 class="text-white font-['Instrument_Serif'] text-3xl">Workspace Design</h3>
        </div>
      </div>

      <!-- Wide card - spans full on lg -->
      <div class="lg:col-span-3 bg-stone-950 rounded-2xl overflow-hidden relative">
        <img src="https://placehold.co/841x450" class="w-full h-64 object-cover" />
        <div class="absolute inset-0 bg-gradient-to-r from-black via-black/40 to-transparent opacity-80"></div>
        <div class="absolute bottom-6 left-6">
          <h3 class="text-white font-['Instrument_Serif'] text-3xl">Modern Interior</h3>
        </div>
      </div>

    </div>
  </section>
</div>

		</div>