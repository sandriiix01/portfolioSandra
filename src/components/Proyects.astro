</div>

<script>
  import { LANG_STORAGE_KEY, translations } from "../i18n/translations";

  const PROYECTS_I18N = {
    es: translations.es.general,
    en: translations.en.general,
  };

  function initProyectsLanguage() {
    const i18nNodes = Array.from(
      document.querySelectorAll<HTMLElement>("[data-i18n-proyects]"),
    );
    const projectTitleNodes = Array.from(
      document.querySelectorAll<HTMLElement>("[data-i18n-project-title]"),
    );
    const projectTagsNodes = Array.from(
      document.querySelectorAll<HTMLElement>("[data-i18n-project-tags]"),
    );

    function sanitizeLang(value: string | null): "es" | "en" {
      return value === "en" ? "en" : "es";
    }

    function parseLocalizedList(node: HTMLElement, lang: "es" | "en") {
      const raw = node.getAttribute(`data-${lang}`) ?? "[]";

      try {
        const parsed = JSON.parse(raw);
        if (!Array.isArray(parsed)) return [];
        return parsed.filter(
          (item): item is string => typeof item === "string",
        );
      } catch {
        return [];
      }
    }

    function applyProyectsLanguage(lang: "es" | "en") {
      const dictionary = PROYECTS_I18N[lang];

      i18nNodes.forEach((node) => {
        const key = node.dataset.i18nProyects as
          | keyof typeof dictionary
          | undefined;
        if (!key) return;
        node.textContent = dictionary[key];
      });

      projectTitleNodes.forEach((node) => {
        const localizedTitle = node.getAttribute(`data-${lang}`)?.trim();
        node.textContent =
          localizedTitle || (lang === "en" ? "Project" : "Proyecto");
      });

      projectTagsNodes.forEach((node) => {
        const localizedTags = parseLocalizedList(node, lang).slice(0, 3);
        const tags =
          localizedTags.length > 0
            ? localizedTags
            : [lang === "en" ? "Project" : "Proyecto"];

        node.innerHTML = "";
        tags.forEach((tag) => {
          const tagNode = document.createElement("span");
          tagNode.className =
            "text-white/60 text-[11px] uppercase tracking-[2.5px]";
          tagNode.textContent = tag;
          node.appendChild(tagNode);
        });
      });
    }

    const initialLang = sanitizeLang(localStorage.getItem(LANG_STORAGE_KEY));
    applyProyectsLanguage(initialLang);

    window.addEventListener("site-language-change", (event) => {
      const customEvent = event as CustomEvent<{ lang?: string }>;
      applyProyectsLanguage(sanitizeLang(customEvent.detail?.lang ?? null));
    });
  }

  document.addEventListener("astro:page-load", initProyectsLanguage);
  initProyectsLanguage();
</script>
