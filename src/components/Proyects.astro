---
import { sanityClient } from "../lib/sanity";

type ProjectImage = {
  url?: string;
  alt?: string;
  titulo?: string;
  descripcion?: string;
  tags?: string[];
  links?: { label?: string; url?: string }[];
  slug?: { current?: string };
};

const proyects = await sanityClient.fetch(`
*[_type == "proyecto"][0..4]{
  titulo,
  descripcioncorta,
  tags,
  links,
  slug,
  imagencover{
    asset->{
      url
    }
  },
}
`);

const projectImages: ProjectImage[] = proyects
  .flatMap(
    (project: {
      titulo?: string;
      descripcioncorta?: string;
      tags?: string[];
      links?: { label?: string; url?: string }[];
      imagencover?: { asset?: { url?: string }; alt?: string };
      slug?: { current?: string };
    }) =>
      (project.imagencover ? [project.imagencover] : []).map((image) => ({
        url: image?.asset?.url,
        alt: image?.alt,
        titulo: project.titulo,
        descripcion: project.descripcioncorta,
        tags: project.tags,
        links: project.links,
        slug: project.slug,
      })),
  )
  .filter((image: ProjectImage) => Boolean(image.url));

const gridImages = Array.from(
  { length: 5 },
  (_, index) => projectImages[index] ?? null,
);

const grid1Slots = [
  { rowSpan: "row-span-7", baseColor: "bg-gray-300", image: gridImages[0] },
  { rowSpan: "row-span-4", baseColor: "bg-gray-400", image: gridImages[1] },
  { rowSpan: "row-span-5", baseColor: "bg-gray-500", image: gridImages[2] },
];

const grid2Slots = [
  { rowSpan: "row-span-5", baseColor: "bg-gray-300", image: gridImages[3] },
  { rowSpan: "row-span-7", baseColor: "bg-gray-400", image: gridImages[4] },
  { rowSpan: "row-span-5", baseColor: "", image: null, isExplore: true },
];

const getProjectHref = (slug?: { current?: string }) =>
  slug?.current ? `/proyecto/${slug.current}` : "#";
---

