            href={getProjectHref(slot.image.slug)}
            class="absolute right-6 bottom-6 rounded-full border border-white/30 bg-black/40 px-4 py-2 text-xs uppercase tracking-[2px] text-white opacity-0 transition-all duration-400 group-hover:opacity-100"
          >
            Ver proyecto
          </a>
        )} */}
