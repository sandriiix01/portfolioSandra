    <!-- Header -->
    <div class="flex flex-col gap-4">
      <span
        class="w-fit bg-white/5 border border-white/10 rounded-full px-4 py-1 text-white/60 text-xs uppercase tracking-[3.6px]"
      >
        Selected Works
      </span>
      <h2
        class="text-white font-['Instrument_Serif'] text-6xl md:text-8xl leading-tight"
      >
        Featured <span class="text-transparent">Projects</span>
      </h2>
    </div>

    <!-- Grid -->
    <div class="flex gap-4 h-auto md:flex-row flex-col">
      <!-- GRID 1 -->
      <div class="grid grid-rows-[repeat(16,minmax(0,1fr))] flex-1 gap-4">
        {
          grid1Slots.map((slot) => (
            <div
              class={`${slot.baseColor} ${slot.rowSpan} relative overflow-hidden rounded-2xl`}
            >
              {slot.image?.url && (
                <a
                  href={getProjectHref(slot.image.slug)}
                  class="h-full rounded-2xl overflow-hidden relative group duration-300 ease-in-out"
                >
                  <img
                    loading="lazy"
                    src={slot.image.url}
                    alt={
                      slot.image.alt ??
                      slot.image.titulo ??
                      "Imagen de proyecto"
