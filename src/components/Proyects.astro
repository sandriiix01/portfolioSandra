  <section class="w-full pt-10 pb-20 flex flex-col gap-16">
    <!-- Header -->
    <div class="flex flex-col gap-4">
      <span data-i18n-proyects="selectedWorks" class="w-fit chip">
        {projectsDictionary[defaultLang].general.selectedWorks}
