                    <div
                      class="flex flex-wrap gap-2"
                      data-i18n-project-tags
                      data-es={JSON.stringify(slot.image.tagsEs ?? [])}
                      data-en={JSON.stringify(slot.image.tagsEn ?? [])}
                    >
                      {(
                        slot.image.tags?.slice(0, 3) ?? [fallbackProjectLabel]
