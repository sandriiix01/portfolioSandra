                //         d="M3 10a.75.75 0 0 1 .75-.75h10.638L10.23 5.29a.75.75 0 1 1 1.04-1.08l5.5 5.25a.75.75 0 0 1 0 1.08l-5.5 5.25a.75.75 0 1 1-1.04-1.08l4.158-3.96H3.75A.75.75 0 0 1 3 10Z"
                //         clip-rule="evenodd"
                //       />
                //     </svg>
                //   </a>
                // </div>
                <a
                  href="/myproyects"
                  class="cursor-pointer group overflow-hidden duration-1000 hover:duration-300 relative w-full h-80 rounded-2xl block"
                >
                  <div class="bg-transparent group-hover:scale-150 -top-12 -right-12 absolute shadow-white/10 shadow-inner rounded-full transition-all ease-in-out group-hover:duration-1000 duration-1000 w-24 h-24" />
                  <div class="bg-transparent group-hover:scale-150 top-44 right-14 absolute shadow-white/20 shadow-inner rounded-full transition-all ease-in-out group-hover:duration-1000 duration-1000 w-24 h-24" />
                  <div class="bg-transparent group-hover:scale-150 top-24 right-56 absolute shadow-white/10 shadow-inner rounded-full transition-all ease-in-out group-hover:duration-1000 duration-1000 w-24 h-24" />
                  <div class="bg-transparent group-hover:scale-150 top-12 right-12 absolute shadow-white/20 shadow-inner rounded-full transition-all ease-in-out group-hover:duration-1000 duration-1000 w-12 h-12" />
                  <div class="bg-transparent group-hover:scale-150 top-12 right-12 absolute shadow-white/20 shadow-inner rounded-full transition-all ease-in-out group-hover:duration-1000 duration-1000 w-44 h-44" />
