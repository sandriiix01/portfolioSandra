---
import Nav from "../components/Nav.astro";

const { title = "Sandra" } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="Portafolio de Sandra, en Madrid" />
    <link rel="icon" type="image/svg+xml" href="/logo-small.svg" />
    <link
      rel="icon"
      type="image/svg+xml"
      sizes="16x16"
      href="/logo-16-16.png"
    />
    <link
      rel="icon"
      type="image/svg+xml"
      sizes="32x32"
      href="/logo-32x32.png"
    />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <meta property="og:title" content="Sandra" />
    <meta
      property="og:description"
      content="Portafolio de Sandra,  en Madrid"
    />
    <meta property="og:image" content="/logo.svg" />
    <meta property="og:image:alt" content="Logo de Sandra" />
    <!-- <link rel="alternate" href="" hreflang="es-GB"> -->
    <link rel="canonical" href="" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta property="twitter:domain" content="" />
    <meta property="twitter:url" content="" />
    <meta name="twitter:title" content="Sandra" />
    <meta
      name="twitter:description"
      content="Portafolio de Sandra, en Madrid"
    />
    <meta name="twitter:image" content="/logo.svg" />
  </head>
  <body>
    <Nav />
    <slot />
  </body>
</html>
<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
