---
import Nav from "../components/Nav.astro";
import { ClientRouter } from "astro:transitions";

const { title = "Sandra" } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="Portafolio de Sandra, en Madrid" />
    <link rel="icon" type="image/svg+xml" href="/logo-small.svg" />
    <link
      rel="icon"
      type="image/svg+xml"
      sizes="16x16"
      href="/logo-16-16.png"
    />
    <link
      rel="icon"
      type="image/svg+xml"
      sizes="32x32"
      href="/logo-32x32.png"
    />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <meta property="og:title" content="Sandra" />
    <meta
      property="og:description"
      content="Portafolio de Sandra,  en Madrid"
    />
    <meta property="og:image" content="/logo.svg" />
    <meta property="og:image:alt" content="Logo de Sandra" />
    <!-- <link rel="alternate" href="" hreflang="es-GB"> -->
    <link rel="canonical" href="" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta property="twitter:domain" content="" />
    <meta property="twitter:url" content="" />
    <meta name="twitter:title" content="Sandra" />
    <meta
      name="twitter:description"
      content="Portafolio de Sandra, en Madrid"
    />
    <meta name="twitter:image" content="/logo.svg" />
    <ClientRouter />
  </head>
  <body>
    <Nav />
    <main transition:name="page-content">
      <slot />
    </main>
  </body>
</html>
<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
  main {
    position: relative; /* Ancla el snapshot correctamente */
    isolation: isolate; /* Crea un stacking context limpio */
    min-height: 100%;
  }

  :root {
    --duration-out: 280ms;
    --duration-in: 520ms;
    --ease-out: cubic-bezier(0.4, 0, 1, 1);
    --ease-in: cubic-bezier(0.22, 1, 0.36, 1);
  }

  /* Desactiva la transición del root por completo */
  ::view-transition-old(root),
  ::view-transition-new(root) {
    animation: none;
  }

  /*
    Fija el grupo para que NO interpole tamaño/posición automáticamente.
    Sin esto el contenedor "morphea" entre las dos snapshots.
  */
  ::view-transition-group(page-content) {
    animation-duration: 0ms;
  }

  ::view-transition-old(page-content) {
    animation: page-out var(--duration-out) var(--ease-out) both;
    z-index: 1;
    mix-blend-mode: normal;
  }

  ::view-transition-new(page-content) {
    animation: page-in var(--duration-in) var(--ease-in) both;
    /* Empieza cuando la vieja termina de salir */
    animation-delay: var(--duration-out);
    z-index: 2;
  }

  @keyframes page-out {
    from {
      opacity: 1;
      filter: blur(0px);
      transform: scale(1);
    }
    to {
      opacity: 0;
      filter: blur(6px);
      transform: scale(0.98);
    }
  }

  @keyframes page-in {
    from {
      opacity: 0;
      /* 100dvh = siempre el alto del viewport, nunca del snapshot */
      transform: translateY(4rem) scale(0.98);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    ::view-transition-old(page-content),
    ::view-transition-new(page-content) {
      animation-duration: 0ms !important;
      animation-delay: 0ms !important;
    }
  }
</style>
