---
import Nav from "../components/Nav.astro";
import { DEFAULT_LANG, translations } from "../i18n/translations";
import { ClientRouter } from "astro:transitions";

const {
  title = "Sandra Guillen | Portfolio de Diseno Visual",
  description = "Portfolio de Sandra Guillen, diseñadora grafica y audiovisual. Explora proyectos de branding, ilustracion, fotografia y direccion de arte.",
  image = "/social-share.png",
  imageAlt = "Diseño de portada de Sandra Guillen, fondo negro con estrellas y texto 'Diseñar con un propósito'",
  imageWidth = 1200,
  imageHeight = 630,
  imageType = "image/png",
  noindex = false,
} = Astro.props;

const canonicalUrl = Astro.site
  ? new URL(Astro.url.pathname, Astro.site).toString()
  : Astro.url.href;

const socialBrandTitle = "Sandra Guillen | Portfolio de Diseño Visual";
const socialBrandDescription =
  "Portfolio de Sandra Guillen, diseñadora gráfica y audiovisual. Explora proyectos de branding, ilustración, fotografía y dirección de arte.";

const ensureSocialTitle = (value: string) => {
  const base = value.trim() || socialBrandTitle;

  if (base.length < 10) {
    return `${base} | Sandra Guillen`;
  }

  if (base.length > 70) {
    return `${base.slice(0, 67).trim()}...`;
  }

  return base;
};

const ensureSocialDescription = (value: string) => {
  const base = value.trim() || socialBrandDescription;

  if (base.length < 50) {
    return `${base} ${socialBrandDescription}`.slice(0, 200).trim();
  }

  if (base.length > 200) {
    return `${base.slice(0, 197).trim()}...`;
  }

  return base;
};

const socialTitle = ensureSocialTitle(title);
const socialDescription = ensureSocialDescription(description);

// Always use absolute URL for social images
const absoluteImageUrl = image?.startsWith("http")
  ? image
  : Astro.site
    ? new URL(image, Astro.site).toString()
    : image;
const defaultLang = DEFAULT_LANG;
const backToTopLabel = translations[defaultLang].general.backToTop;
const backToTopLabelEs = translations.es.general.backToTop;
const backToTopLabelEn = translations.en.general.backToTop;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta
      name="robots"
      content={noindex ? "noindex, nofollow" : "index, follow"}
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" sizes="any" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:title" content={socialTitle} />
    <meta property="og:description" content={socialDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={absoluteImageUrl} />
    <meta property="og:image:alt" content={imageAlt} />
    <meta property="og:image:width" content={imageWidth} />
    <meta property="og:image:height" content={imageHeight} />
    <meta property="og:image:type" content={imageType} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalUrl} />
    <meta name="twitter:title" content={socialTitle} />
    <meta name="twitter:description" content={socialDescription} />
    <meta name="twitter:image" content={absoluteImageUrl} />
    <meta name="twitter:image:alt" content={imageAlt} />
    <ClientRouter />
  </head>
  <body>
    <div id="particles-js" class="inset-0 z-0"></div>
    <Nav />
    <main transition:name="page-content" class="">
      <slot />
    </main>
    <button
      id="back-to-top"
      type="button"
      class="back-to-top"
      aria-label={backToTopLabel}
      title={backToTopLabel}
      data-label-es={backToTopLabelEs}
      data-label-en={backToTopLabelEn}
    >
      <span aria-hidden="true">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
        >
          <path
            d="M11.25 20C11.25 20.4142 11.5858 20.75 12 20.75C12.4142 20.75 12.75 20.4142 12.75 20H11.25ZM12.75 20L12.75 4L11.25 4L11.25 20H12.75Z"
            fill="currentColor"></path>
          <path
            d="M18 10L12 4L6 10"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </span>
      <span class="sr-only" data-i18n-back-to-top>{backToTopLabel}</span>
    </button>
  </body>
</html>
<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
    position: relative;
  }
  main {
    position: relative; /* Ancla el snapshot correctamente */
    isolation: isolate; /* Crea un stacking context limpio */
    min-height: 100%;
  }

  :root {
    --duration-out: 280ms;
    --duration-in: 520ms;
    --ease-out: cubic-bezier(0.4, 0, 1, 1);
    --ease-in: cubic-bezier(0.22, 1, 0.36, 1);
  }

  /* Desactiva la transición del root por completo */
  ::view-transition-old(root),
  ::view-transition-new(root) {
    animation: none;
  }

  /*
    Fija el grupo para que NO interpole tamaño/posición automáticamente.
    Sin esto el contenedor "morphea" entre las dos snapshots.
  */
  ::view-transition-group(page-content) {
    animation-duration: 0ms;
  }

  ::view-transition-old(page-content) {
    animation: page-out var(--duration-out) var(--ease-out) both;
    z-index: 1;
    mix-blend-mode: normal;
  }

  ::view-transition-new(page-content) {
    animation: page-in var(--duration-in) var(--ease-in) both;
    /* Empieza cuando la vieja termina de salir */
    animation-delay: var(--duration-out);
    z-index: 2;
  }

  @keyframes page-out {
    from {
      opacity: 1;
      filter: blur(0px);
      transform: scale(1);
    }
    to {
      opacity: 0;
      filter: blur(6px);
      transform: scale(0.98);
    }
  }

  @keyframes page-in {
    from {
      opacity: 0;
      /* 100dvh = siempre el alto del viewport, nunca del snapshot */
      transform: translateY(4rem) scale(0.98);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    ::view-transition-old(page-content),
    ::view-transition-new(page-content) {
      animation-duration: 0ms !important;
      animation-delay: 0ms !important;
    }
  }
  canvas {
    display: block;
    vertical-align: bottom;
  }
  #particles-js {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  nav,
  main {
    position: relative;
    z-index: 1;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .back-to-top {
    position: fixed;
    right: max(1.5rem, calc((100vw - 1800px) / 2 + 1.5rem));
    bottom: 4rem;
    width: 4rem;
    height: 4rem;
    border: 1px solid rgba(255, 255, 255, 0.28);
    border-radius: 9999px;
    background: rgba(14, 14, 14, 0.72);
    color: #ffffff;
    font-size: 1.3rem;
    line-height: 1;
    cursor: pointer;
    display: grid;
    place-items: center;
    box-shadow: 0 10px 28px rgba(0, 0, 0, 0.34);
    backdrop-filter: blur(5px);
    -webkit-backdrop-filter: blur(5px);
    opacity: 0;
    transform: translateY(0.75rem);
    pointer-events: none;
    transition:
      opacity 220ms ease,
      transform 220ms ease,
      border-color 220ms ease,
      background-color 220ms ease;
    z-index: 140;
    background: #1f2020;
  }

  .back-to-top svg {
    width: 1.15rem;
    height: 1.15rem;
    display: block;
  }

  .back-to-top:hover,
  .back-to-top:focus-visible {
    opacity: 1;
    border-color: rgba(255, 255, 255, 0.55);
    background: rgba(24, 24, 24, 0.88);
    transform: translateY(0);
  }

  .back-to-top:focus-visible {
    outline: 2px solid rgba(255, 255, 255, 0.8);
    outline-offset: 2px;
  }

  .back-to-top.is-visible {
    opacity: 0.78;
    transform: translateY(0);
    visibility: visible;
    pointer-events: auto;
  }

  @media (max-width: 640px) {
    .back-to-top {
      width: 3rem;
      height: 3rem;
      right: 1.5rem;
      bottom: 4rem;
    }
  }

  @media (min-width: 640px) {
    .back-to-top {
      right: max(3rem, calc((100vw - 1800px) / 2 + 3rem));
    }
  }

  @media (min-width: 1024px) {
    .back-to-top {
      right: max(6rem, calc((100vw - 1800px) / 2 + 6rem));
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .back-to-top {
      transition: none;
    }
  }
</style>
<script
  is:inline
  src="https://cdn.jsdelivr.net/particles.js/2.0.0/particles.min.js"></script>
<script is:inline>
  const particlesConfig = {
    particles: {
      number: {
        value: 200,
        density: {
          enable: true,
          value_area: 800,
        },
      },
      color: {
        value: "#ffffff",
      },
      shape: {
        type: "circle",
      },
      opacity: {
        value: 0.35,
        random: true,
      },
      size: {
        value: 2,
        random: false,
        anim: {
          enable: false,
        },
      },
      line_linked: {
        enable: false,
        opacity: 0.2,
      },
      move: {
        enable: true,
        speed: 1,
        direction: "none",
        random: true,
        straight: false,
        out_mode: "out",
        bounce: false,
        attract: {
          enable: false,
          rotateX: 600,
          rotateY: 1200,
        },
      },
    },
    interactivity: {
      detect_on: "window",
      events: {
        onhover: {
          enable: true,
          mode: "bubble",
        },
        onclick: {
          enable: false,
        },
        resize: true,
      },
      modes: {
        bubble: {
          distance: 200,
          size: 2.2,
          duration: 2,
          opacity: 1,
          speed: 3,
        },
      },
    },
    retina_detect: true,
  };

  function destroyParticles(containerId) {
    if (!Array.isArray(window.pJSDom)) {
      return;
    }

    window.pJSDom = window.pJSDom.filter((instance) => {
      const canvas = instance?.pJS?.canvas?.el;
      if (canvas?.parentElement?.id === containerId) {
        instance?.pJS?.fn?.vendors?.destroypJS?.();
        return false;
      }
      return true;
    });
  }

  function initParticles() {
    if (typeof window.particlesJS !== "function") {
      return;
    }

    destroyParticles("particles-js");
    window.particlesJS("particles-js", particlesConfig);
  }

  initParticles();

  if (!window.__particlesPageLoadHook__) {
    document.addEventListener("astro:page-load", initParticles);
    window.__particlesPageLoadHook__ = true;
  }

  function initBackToTop() {
    const button = document.getElementById("back-to-top");
    if (!button) {
      return;
    }

    const reduceMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;

    function sanitizeLang(value) {
      return value === "en" ? "en" : "es";
    }

    function applyBackToTopLanguage(lang) {
      const label =
        lang === "en" ? button.dataset.labelEn : button.dataset.labelEs;
      if (!label) {
        return;
      }

      button.setAttribute("aria-label", label);
      button.setAttribute("title", label);

      const labelNode = button.querySelector("[data-i18n-back-to-top]");
      if (labelNode) {
        labelNode.textContent = label;
      }
    }

    const storedLang = sanitizeLang(localStorage.getItem("site-lang"));
    applyBackToTopLanguage(storedLang);

    function setVisible(isVisible) {
      if (isVisible) {
        button.classList.add("is-visible");
      } else {
        button.classList.remove("is-visible");
      }
    }

    button.onclick = () => {
      window.scrollTo({
        top: 0,
        behavior: reduceMotion ? "auto" : "smooth",
      });
    };

    if (window.__backToTopScrollHandler__) {
      window.removeEventListener("scroll", window.__backToTopScrollHandler__);
      window.removeEventListener("resize", window.__backToTopScrollHandler__);
      window.__backToTopScrollHandler__ = null;
    }

    const updateVisibility = () => {
      const scrollingElement =
        document.scrollingElement || document.documentElement;
      const scrollTop = Math.max(
        scrollingElement.scrollTop || 0,
        window.scrollY || 0,
      );
      setVisible(scrollTop > 120);
    };

    updateVisibility();
    window.addEventListener("scroll", updateVisibility, { passive: true });
    window.addEventListener("resize", updateVisibility);
    window.__backToTopScrollHandler__ = updateVisibility;

    if (window.__backToTopLangHandler__) {
      window.removeEventListener(
        "site-language-change",
        window.__backToTopLangHandler,
      );
    }

    window.__backToTopLangHandler__ = (event) => {
      const customEvent = event;
      applyBackToTopLanguage(sanitizeLang(customEvent?.detail?.lang ?? null));
    };

    window.addEventListener(
      "site-language-change",
      window.__backToTopLangHandler,
    );
  }

  initBackToTop();

  if (!window.__backToTopPageLoadHook__) {
    document.addEventListener("astro:page-load", initBackToTop);
    window.__backToTopPageLoadHook__ = true;
  }
</script>
