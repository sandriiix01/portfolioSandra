---
import Nav from "../components/Nav.astro";
import { ClientRouter } from "astro:transitions";

const { title = "Sandra" } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="Portafolio de Sandra, en Madrid" />
    <link rel="icon" type="image/svg+xml" href="/logo-small.svg" />
    <link
      rel="icon"
      type="image/svg+xml"
      sizes="16x16"
      href="/logo-16-16.png"
    />
    <link
      rel="icon"
      type="image/svg+xml"
      sizes="32x32"
      href="/logo-32x32.png"
    />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <meta property="og:title" content="Sandra" />
    <meta
      property="og:description"
      content="Portafolio de Sandra,  en Madrid"
    />
    <meta property="og:image" content="/logo.svg" />
    <meta property="og:image:alt" content="Logo de Sandra" />
    <!-- <link rel="alternate" href="" hreflang="es-GB"> -->
    <link rel="canonical" href="" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta property="twitter:domain" content="" />
    <meta property="twitter:url" content="" />
    <meta name="twitter:title" content="Sandra" />
    <meta
      name="twitter:description"
      content="Portafolio de Sandra, en Madrid"
    />
    <meta name="twitter:image" content="/logo.svg" />
    <ClientRouter />
  </head>
  <body>
    <div id="particles-js" class="inset-0 z-0"></div>
    <Nav />
    <main transition:name="page-content" class="">
      <slot />
    </main>
  </body>
</html>
<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
    position: relative;
  }
  main {
    position: relative; /* Ancla el snapshot correctamente */
    isolation: isolate; /* Crea un stacking context limpio */
    min-height: 100%;
  }

  :root {
    --duration-out: 280ms;
    --duration-in: 520ms;
    --ease-out: cubic-bezier(0.4, 0, 1, 1);
    --ease-in: cubic-bezier(0.22, 1, 0.36, 1);
  }

  /* Desactiva la transición del root por completo */
  ::view-transition-old(root),
  ::view-transition-new(root) {
    animation: none;
  }

  /*
    Fija el grupo para que NO interpole tamaño/posición automáticamente.
    Sin esto el contenedor "morphea" entre las dos snapshots.
  */
  ::view-transition-group(page-content) {
    animation-duration: 0ms;
  }

  ::view-transition-old(page-content) {
    animation: page-out var(--duration-out) var(--ease-out) both;
    z-index: 1;
    mix-blend-mode: normal;
  }

  ::view-transition-new(page-content) {
    animation: page-in var(--duration-in) var(--ease-in) both;
    /* Empieza cuando la vieja termina de salir */
    animation-delay: var(--duration-out);
    z-index: 2;
  }

  @keyframes page-out {
    from {
      opacity: 1;
      filter: blur(0px);
      transform: scale(1);
    }
    to {
      opacity: 0;
      filter: blur(6px);
      transform: scale(0.98);
    }
  }

  @keyframes page-in {
    from {
      opacity: 0;
      /* 100dvh = siempre el alto del viewport, nunca del snapshot */
      transform: translateY(4rem) scale(0.98);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    ::view-transition-old(page-content),
    ::view-transition-new(page-content) {
      animation-duration: 0ms !important;
      animation-delay: 0ms !important;
    }
  }
  canvas {
    display: block;
    vertical-align: bottom;
  }
  #particles-js {
  position: fixed;
  inset: 0;
  z-index: 0;
  pointer-events: none;
}

nav,
main {
  position: relative;
  z-index: 1;
}
</style>
<script is:inline src="https://cdn.jsdelivr.net/particles.js/2.0.0/particles.min.js"></script>
<script is:inline>
  const particlesConfig = {
    particles: {
      number: {
        value: 200,
        density: {
          enable: true,
          value_area: 800,
        },
      },
      color: {
        value: "#ffffff",
      },
      shape: {
        type: "circle",
      },
      opacity: {
        value: 0.35,
        random: true,
      },
      size: {
        value: 2,
        random: false,
        anim: {
          enable: false,
        },
      },
      line_linked: {
        enable: false,
        opacity: 0.2,
      },
      move: {
        enable: true,
        speed: 1,
        direction: "none",
        random: true,
        straight: false,
        out_mode: "out",
        bounce: false,
        attract: {
          enable: false,
          rotateX: 600,
          rotateY: 1200,
        },
      },
    },
    interactivity: {
      detect_on: "window",
      events: {
        onhover: {
          enable: true,
          mode: "bubble",
        },
        onclick: {
          enable: false,
        },
        resize: true,
      },
      modes: {
        bubble: {
          distance: 200,
          size: 2.2,
          duration: 2,
          opacity: 1,
          speed: 3,
        },
      },
    },
    retina_detect: true,
  };

  function destroyParticles(containerId) {
    if (!Array.isArray(window.pJSDom)) {
      return;
    }

    window.pJSDom = window.pJSDom.filter((instance) => {
      const canvas = instance?.pJS?.canvas?.el;
      if (canvas?.parentElement?.id === containerId) {
        instance?.pJS?.fn?.vendors?.destroypJS?.();
        return false;
      }
      return true;
    });
  }

  function initParticles() {
    if (typeof window.particlesJS !== "function") {
      return;
    }

    destroyParticles("particles-js");
    window.particlesJS("particles-js", particlesConfig);
  }

  initParticles();

  if (!window.__particlesPageLoadHook__) {
    document.addEventListener("astro:page-load", initParticles);
    window.__particlesPageLoadHook__ = true;
  }
</script>